{
  "slug": "refresh-cookies",
  "title": "Refresh Cookies",
  "description": "Update and re-synchronize cookies for an existing account",
  "category": "Account",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/accounts/cookies",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint updates and synchronizes cookies for an existing account using its account hash. Use this when your account cookies have expired or need to be refreshed.",
    "sections": {
      "bodyParameters": {
        "title": "Request Body",
        "parameters": [
          {
            "name": "account",
            "type": "string",
            "required": true,
            "description": "Existing account hash to update",
            "example": "\"abfeb440ceccdfab974e8d261836c9d6\""
          },
          {
            "name": "type",
            "type": "string",
            "required": true,
            "description": "Account type identifier",
            "example": "\"twitter-sync\""
          },
          {
            "name": "cookies",
            "type": "object",
            "required": true,
            "description": "Object containing updated cookie name-value pairs",
            "example": "{\"auth_token\": \"...\", \"ct0\": \"...\"}"
          }
        ]
      },
      "responseFields": {
        "title": "Response Field Explanations",
        "fields": [
          {
            "path": "id",
            "type": "string",
            "description": "Synchronization task identifier",
            "example": "\"7966b678b6b63ef599deeea99cb2b219\""
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"synchronize-cookies\"",
            "example": "\"synchronize-cookies\""
          },
          {
            "path": "status_code",
            "type": "integer",
            "description": "Task status code (100 = created)",
            "example": "100"
          },
          {
            "path": "status_text",
            "type": "string",
            "description": "Human-readable status",
            "example": "\"created\""
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Must be application/json"
      }
    ],
    "proTips": [
      {
        "type": "warning",
        "content": "Refresh cookies immediately when you notice status_code_info showing 'cookies_expired' in List Accounts or Get Account Details."
      },
      {
        "type": "tip",
        "content": "Use the returned task ID with Check Sync Status to monitor the refresh process."
      },
      {
        "type": "note",
        "content": "Refreshing cookies preserves all account settings and limits. You don't need to reconfigure the account after refresh."
      },
      {
        "type": "tip",
        "content": "Set up monitoring to check account status regularly and automate cookie refresh when needed."
      }
    ]
  },
  "seo": {
    "title": "Refresh Cookies - lobstr.io API Documentation",
    "description": "Learn how to update and re-synchronize cookies for existing platform accounts using the lobstr.io API."
  }
}
