        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Must be application/json"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Subscribe only to events you need. For most use cases, run.done and run.error are sufficient."
      },
      {
        "type": "warning",
        "content": "Your webhook endpoint must respond within 30 seconds or the delivery will be marked as failed."
      },
      {
        "type": "tip",
        "content": "Enable retry for production webhooks to handle temporary network issues or server downtime automatically."
      },
      {
        "type": "note",
        "content": "Webhook payloads are sent as JSON with Content-Type: application/json header. Parse the request body to extract event data."
      },
      {
        "type": "tip",
        "content": "Use the Test Webhook endpoint to verify your endpoint is accessible and responding correctly before activating webhooks."
      },
      {
        "type": "warning",
        "content": "Implement proper authentication/validation in your webhook endpoint to ensure requests are coming from lobstr.io."
      }
    ]
  },
  "seo": {
    "title": "Configure Webhook Delivery - lobstr.io API Documentation",
    "description": "Learn how to set up real-time webhook notifications for squid events using the lobstr.io API. Configure event subscriptions and retry policies."
  }
