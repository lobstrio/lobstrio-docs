{
  "slug": "list-squids",
  "title": "List Squids",
  "description": "Retrieve a paginated list of all your squids with filtering and search capabilities",
  "category": "Squid",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/squids",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint returns a paginated list of all squids belonging to the authenticated user. You can search by name and control pagination with query parameters.",
    "sections": {
      "responseStructure": {
        "title": "Response Structure",
        "fields": [
          {
            "path": "total_results",
            "type": "integer",
            "description": "Total number of squids matching the query",
            "example": "15"
          },
          {
            "path": "limit",
            "type": "integer",
            "description": "Number of results per page",
            "example": "50"
          },
          {
            "path": "page",
            "type": "integer",
            "description": "Current page number",
            "example": "1"
          },
          {
            "path": "total_pages",
            "type": "integer",
            "description": "Total number of pages available",
            "example": "1"
          },
          {
            "path": "result_from",
            "type": "integer",
            "description": "Starting index of results in current page",
            "example": "1"
          },
          {
            "path": "result_to",
            "type": "integer",
            "description": "Ending index of results in current page",
            "example": "15"
          },
          {
            "path": "data",
            "type": "array",
            "description": "Array of squid objects with comprehensive details"
          },
          {
            "path": "next",
            "type": "string | null",
            "description": "Full URL to the next page (null if on last page)",
            "example": "null"
          },
          {
            "path": "previous",
            "type": "string | null",
            "description": "Full URL to the previous page (null if on first page)",
            "example": "null"
          }
        ]
      },
      "squidObjectFields": {
        "title": "Squid Object Fields",
        "fields": [
          {
            "path": "data[].id",
            "type": "string",
            "description": "Unique squid identifier",
            "example": "\"c106a44a98044ef18acc59986ae10967\""
          },
          {
            "path": "data[].name",
            "type": "string",
            "description": "Display name of the squid",
            "example": "\"Google Maps (1)\""
          },
          {
            "path": "data[].created_at",
            "type": "string",
            "description": "Timestamp when the squid was created",
            "example": "\"2024-01-15T10:30:00Z\""
          },
          {
            "path": "data[].is_active",
            "type": "boolean",
            "description": "Whether the squid is active and can run",
            "example": "true"
          },
          {
            "path": "data[].is_ready",
            "type": "boolean",
            "description": "Whether the squid has tasks and is ready to run",
            "example": "true"
          },
          {
            "path": "data[].crawler",
            "type": "string",
            "description": "Unique identifier of the associated crawler",
            "example": "\"4734d096159ef05210e0e1677e8be823\""
          },
          {
            "path": "data[].crawler_name",
            "type": "string",
            "description": "Display name of the crawler",
            "example": "\"Google Maps Search Export\""
          },
          {
            "path": "data[].icon",
            "type": "string",
            "description": "URL to the crawler's icon image",
            "example": "\"https://cdn.lobstr.io/icons/google-maps.png\""
          },
          {
            "path": "data[].is_public",
            "type": "boolean",
            "description": "Whether the crawler is publicly available",
            "example": "true"
          },
          {
            "path": "data[].concurrency",
            "type": "integer",
            "description": "Number of concurrent tasks the squid runs",
            "example": "2"
          },
          {
            "path": "data[].params",
            "type": "object",
            "description": "Crawler-specific parameter configuration object",
            "example": "{\"language\": \"en\"}"
          },
          {
            "path": "data[].to_complete",
            "type": "boolean",
            "description": "Whether to stop after completing all tasks",
            "example": "false"
          },
          {
            "path": "data[].export_unique_results",
            "type": "boolean",
            "description": "Whether to export only unique results",
            "example": "true"
          },
          {
            "path": "data[].no_line_breaks",
            "type": "boolean",
            "description": "Whether to remove line breaks from exported data",
            "example": "false"
          },
          {
            "path": "data[].last_run_status",
            "type": "string",
            "description": "Status of the most recent run (completed, running, error, etc.)",
            "example": "\"DONE\""
          },
          {
            "path": "data[].last_run_at",
            "type": "string",
            "description": "Timestamp of the most recent run",
            "example": "\"2024-01-20T15:45:00Z\""
          },
          {
            "path": "data[].total_runs",
            "type": "integer",
            "description": "Total number of times the squid has been executed",
            "example": "5"
          },
          {
            "path": "data[].next_launch_at",
            "type": "string | null",
            "description": "Scheduled time for the next automated run (null if not scheduled)",
            "example": "\"2024-01-21T10:00:00Z\""
          },
          {
            "path": "data[].google_sheet_fields",
            "type": "object | null",
            "description": "Google Sheets integration configuration (null if not configured)",
            "example": "null"
          },
          {
            "path": "data[].ftp_fields",
            "type": "object | null",
            "description": "FTP integration configuration (null if not configured)",
            "example": "null"
          },
          {
            "path": "data[].s3_fields",
            "type": "object | null",
            "description": "AWS S3 integration configuration (null if not configured)",
            "example": "null"
          },
          {
            "path": "data[].webhook_fields",
            "type": "object | null",
            "description": "Webhook integration configuration (null if not configured)",
            "example": "null"
          },
          {
            "path": "data[].schedule",
            "type": "string | null",
            "description": "Cron expression for scheduled runs (null if not scheduled)",
            "example": "\"0 10 * * *\""
          },
          {
            "path": "data[].schedule_time",
            "type": "string",
            "description": "Human-readable schedule description",
            "example": "\"Daily at 10:00 AM\""
          },
          {
            "path": "data[].download_url",
            "type": "string | null",
            "description": "Temporary signed URL to download results (null if no results available)",
            "example": "\"https://storage.lobstr.io/downloads/xyz123...\""
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "name",
        "type": "string",
        "required": false,
        "description": "Filter squids by name (case-insensitive partial match)",
        "example": "Google"
      },
      {
        "name": "limit",
        "type": "integer",
        "required": false,
        "description": "Number of results per page",
        "default": "50",
        "example": "10"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number for pagination",
        "default": "1",
        "example": "2"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use the 'name' query parameter to quickly find squids. It performs a case-insensitive partial match on squid names."
      },
      {
        "type": "note",
        "content": "The 'next' and 'previous' fields contain full URLs for easy pagination. Use them directly to navigate through pages."
      },
      {
        "type": "tip",
        "content": "Check 'last_run_status' to see if a squid has completed, is running, or encountered errors. Useful for monitoring multiple squids."
      },
      {
        "type": "warning",
        "content": "Squids with 'is_ready: false' haven't been configured with tasks yet. Add tasks before starting a run."
      },
      {
        "type": "tip",
        "content": "The 'download_url' field provides a temporary signed URL to download results. URLs expire after a certain time period."
      }
    ]
  },
  "seo": {
    "title": "List Squids - lobstr.io API Documentation",
    "description": "Learn how to retrieve and filter your squids using the lobstr.io API. Includes pagination, search, and response field details."
  }
}
