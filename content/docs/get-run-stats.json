{
  "slug": "get-run-stats",
  "title": "Get Run Stats",
  "description": "Retrieve detailed statistics about a specific run",
  "category": "Run",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/runs/{run_hash}/stats",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint retrieves detailed real-time statistics about a specific run, including progress information, estimated time remaining, and task completion status.",
    "sections": {
      "responseFields": {
        "title": "Response Field Explanations",
        "fields": [
          {
            "path": "id",
            "type": "string",
            "description": "The run's unique identifier",
            "example": "\"300e9c5c127d421c90f431478d9a2cfb\""
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"run\"",
            "example": "\"run\""
          },
          {
            "path": "duration",
            "type": "string",
            "description": "Human-readable duration (HH:MM:SS format)",
            "example": "\"0:00:15.175532\""
          },
          {
            "path": "started_at",
            "type": "string",
            "description": "When the run started",
            "example": "\"2025-02-10T14:30:55\""
          },
          {
            "path": "ended_at",
            "type": "string | null",
            "description": "When the run ended (null if still running)",
            "example": "\"2025-02-10T14:31:10\""
          },
          {
            "path": "is_done",
            "type": "boolean",
            "description": "Whether the run has completed",
            "example": "true"
          },
          {
            "path": "percent_done",
            "type": "string",
            "description": "Completion percentage",
            "example": "\"100%\""
          },
          {
            "path": "eta",
            "type": "string",
            "description": "Estimated time remaining (\"∞\" if unknown)",
            "example": "\"∞\""
          },
          {
            "path": "total_tasks",
            "type": "integer",
            "description": "Total number of tasks in the run",
            "example": "10"
          },
          {
            "path": "total_tasks_done",
            "type": "integer",
            "description": "Number of tasks completed",
            "example": "10"
          },
          {
            "path": "total_tasks_left",
            "type": "integer",
            "description": "Number of tasks remaining",
            "example": "0"
          },
          {
            "path": "total_results",
            "type": "integer",
            "description": "Total results collected in this run",
            "example": "6"
          },
          {
            "path": "results_total",
            "type": "integer",
            "description": "Expected total results (if known)",
            "example": "138"
          },
          {
            "path": "results_done",
            "type": "integer",
            "description": "Results collected so far",
            "example": "6"
          },
          {
            "path": "current_task",
            "type": "string",
            "description": "Currently executing task (empty if none)",
            "example": "\"\""
          },
          {
            "path": "updated_at",
            "type": "string",
            "description": "Last update timestamp",
            "example": "\"2025-02-10T14:31:10\""
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "run_hash",
        "type": "string",
        "required": true,
        "description": "The unique identifier (hash) of the run",
        "example": "300e9c5c127d421c90f431478d9a2cfb"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Poll this endpoint periodically to display real-time progress in your application."
      },
      {
        "type": "note",
        "content": "The eta field provides an estimate but may show \"∞\" for runs with unpredictable completion times."
      },
      {
        "type": "tip",
        "content": "Use percent_done for progress bars and total_tasks_left to show remaining work."
      }
    ]
  },
  "seo": {
    "title": "Get Run Stats - lobstr.io API Documentation",
    "description": "Learn how to retrieve real-time statistics for a scraping run using the lobstr.io API."
  }
}
