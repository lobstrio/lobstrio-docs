{
  "slug": "list-accounts",
  "title": "List Accounts",
  "description": "Retrieve a paginated list of all connected platform accounts",
  "category": "Account",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/accounts",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint retrieves a paginated list of all connected platform accounts (like Twitter, LinkedIn, Facebook) associated with the authenticated user.",
    "sections": {
      "responseStructure": {
        "title": "Response Structure",
        "fields": [
          {
            "path": "total_results",
            "type": "integer",
            "description": "Total number of accounts",
            "example": "2"
          },
          {
            "path": "limit",
            "type": "integer",
            "description": "Maximum results per page",
            "example": "50"
          },
          {
            "path": "page",
            "type": "integer",
            "description": "Current page number",
            "example": "1"
          },
          {
            "path": "total_pages",
            "type": "integer",
            "description": "Total number of pages",
            "example": "1"
          },
          {
            "path": "result_from",
            "type": "integer",
            "description": "Starting result index",
            "example": "1"
          },
          {
            "path": "result_to",
            "type": "integer",
            "description": "Ending result index",
            "example": "3"
          },
          {
            "path": "data",
            "type": "array",
            "description": "Array of account objects",
            "example": "[...]"
          },
          {
            "path": "next",
            "type": "string | null",
            "description": "URL for next page (null if last page)",
            "example": "null"
          },
          {
            "path": "previous",
            "type": "string | null",
            "description": "URL for previous page (null if first page)",
            "example": "null"
          }
        ]
      },
      "accountFields": {
        "title": "Account Object Fields",
        "fields": [
          {
            "path": "id",
            "type": "string",
            "description": "Unique account identifier",
            "example": "\"6e5f36d27502ec69fda745ec59ead509\""
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"account\"",
            "example": "\"account\""
          },
          {
            "path": "username",
            "type": "string",
            "description": "Platform username",
            "example": "\"MisterDebugger\""
          },
          {
            "path": "created_at",
            "type": "string",
            "description": "Account creation timestamp (ISO 8601)",
            "example": "\"2025-02-11T08:28:14Z\""
          },
          {
            "path": "last_synchronization_time",
            "type": "string",
            "description": "Last sync timestamp",
            "example": "\"2025-02-11T08:28:14Z\""
          },
          {
            "path": "status",
            "type": "string",
            "description": "HTTP status code",
            "example": "\"200\""
          },
          {
            "path": "status_code_info",
            "type": "string",
            "description": "Status information",
            "example": "\"synchronized\""
          },
          {
            "path": "status_code_description",
            "type": "string",
            "description": "Human-readable status message",
            "example": "\"Success!\""
          },
          {
            "path": "type",
            "type": "string",
            "description": "Account type identifier",
            "example": "\"facebook-sync\""
          },
          {
            "path": "params",
            "type": "object",
            "description": "Account parameters (default and user-specific)",
            "example": "{\"default\": {}, \"user\": {}}"
          },
          {
            "path": "updated_at",
            "type": "string | null",
            "description": "Last update timestamp",
            "example": "null"
          },
          {
            "path": "account_type_hash",
            "type": "string",
            "description": "Account type identifier hash",
            "example": "\"16f5b7f91e8fc533eab88be973273a02\""
          },
          {
            "path": "squids",
            "type": "array",
            "description": "Array of squids using this account",
            "example": "[]"
          },
          {
            "path": "baseurl",
            "type": "string",
            "description": "Platform base URL",
            "example": "\"https://www.facebook.com\""
          },
          {
            "path": "cookies",
            "type": "array",
            "description": "Required cookie names for authentication",
            "example": "[{\"name\": \"c_user\", \"required\": true}]"
          },
          {
            "path": "icon",
            "type": "string",
            "description": "Base64 encoded platform icon",
            "example": "\"<base64 image data>\""
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use this endpoint to check which platform accounts are currently synced and their status before running squids that require authentication."
      },
      {
        "type": "note",
        "content": "The squids array shows which squids are currently using each account, helping you manage account usage across your projects."
      },
      {
        "type": "warning",
        "content": "Check the status_code_info field to identify accounts with expired cookies that need re-synchronization."
      }
    ]
  },
  "seo": {
    "title": "List Accounts - lobstr.io API Documentation",
    "description": "Learn how to retrieve all connected platform accounts using the lobstr.io API. List Twitter, LinkedIn, Facebook and other platform credentials."
  }
}
