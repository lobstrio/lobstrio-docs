{
  "slug": "list-runs",
  "title": "List Runs",
  "description": "Retrieve a paginated list of all runs for a specific squid",
  "category": "Run",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/runs",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint retrieves a paginated list of all runs for a specific squid. Use this to view run history and track past executions.",
    "sections": {
      "queryParameters": {
        "title": "Query Parameters",
        "columns": [
          {"header": "Parameter", "key": "param"},
          {"header": "Type", "key": "type"},
          {"header": "Required", "key": "required"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"param": "**squid**", "type": "string", "required": "Yes", "description": "The squid hash ID to list runs for"},
          {"param": "**page**", "type": "integer", "required": "No", "description": "Page number for pagination. Default: 1"},
          {"param": "**limit**", "type": "integer", "required": "No", "description": "Results per page. Default: 50, Max: 100"}
        ]
      },
      "responseFields": {
        "title": "Response Field Explanations",
        "fields": [
          {
            "path": "total_results",
            "type": "integer",
            "description": "Total number of runs",
            "example": "4"
          },
          {
            "path": "limit",
            "type": "integer",
            "description": "Maximum results per page",
            "example": "50"
          },
          {
            "path": "page",
            "type": "integer",
            "description": "Current page number",
            "example": "1"
          },
          {
            "path": "total_pages",
            "type": "integer",
            "description": "Total number of pages",
            "example": "1"
          },
          {
            "path": "data",
            "type": "array",
            "description": "Array of run objects",
            "example": "[...]"
          },
          {
            "path": "data[].id",
            "type": "string",
            "description": "Unique run identifier",
            "example": "\"381cfbb47e474782857ddc035298b6f3\""
          },
          {
            "path": "data[].status",
            "type": "string",
            "description": "Current run status",
            "example": "\"done\""
          },
          {
            "path": "data[].is_done",
            "type": "boolean",
            "description": "Whether the run has completed",
            "example": "true"
          },
          {
            "path": "data[].total_results",
            "type": "integer",
            "description": "Number of results collected",
            "example": "156"
          },
          {
            "path": "data[].duration",
            "type": "float",
            "description": "Run duration in seconds",
            "example": "3.1849"
          },
          {
            "path": "data[].credit_used",
            "type": "float",
            "description": "Credits consumed",
            "example": "3.1849"
          },
          {
            "path": "data[].done_reason",
            "type": "string | null",
            "description": "Reason for completion",
            "example": "\"tasks_done\""
          },
          {
            "path": "next",
            "type": "string | null",
            "description": "URL for next page (null if last page)",
            "example": "null"
          },
          {
            "path": "previous",
            "type": "string | null",
            "description": "URL for previous page (null if first page)",
            "example": "null"
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use this endpoint to monitor all past and current runs for a squid."
      },
      {
        "type": "note",
        "content": "Runs are returned in reverse chronological order (newest first)."
      },
      {
        "type": "tip",
        "content": "Check is_done to quickly filter completed vs. active runs."
      }
    ]
  },
  "seo": {
    "title": "List Runs - lobstr.io API Documentation",
    "description": "Learn how to retrieve a list of all runs for a squid using the lobstr.io API."
