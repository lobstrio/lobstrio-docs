{
  "slug": "check-upload-status",
  "title": "Check Upload Status",
  "description": "Monitor the status of a task upload operation",
  "category": "Task",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/tasks/upload/{upload_task_id}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint checks the status of a task upload operation using the upload task ID returned from the Upload Tasks endpoint.",
    "sections": {
      "responseFields": {
        "title": "Response Field Explanations",
        "fields": [
          {
            "path": "id",
            "type": "string",
            "description": "Upload task identifier",
            "example": "\"427a7bfc54cf4ce483d83ba23425164b\""
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"task_upload\"",
            "example": "\"task_upload\""
          },
          {
            "path": "state",
            "type": "string",
            "description": "Current upload state (PENDING, PROGRESS, SUCCESS, FAILURE)",
            "example": "\"SUCCESS\""
          },
          {
            "path": "meta.duplicates",
            "type": "integer",
            "description": "Number of duplicate tasks skipped",
            "example": "0"
          },
          {
            "path": "meta.inserted",
            "type": "integer",
            "description": "Number of tasks successfully inserted",
            "example": "8"
          },
          {
            "path": "meta.invalid",
            "type": "integer",
            "description": "Number of invalid rows in the file",
            "example": "0"
          },
          {
            "path": "meta.valid",
            "type": "integer",
            "description": "Number of valid rows processed",
            "example": "8"
          }
        ]
      },
      "stateValues": {
        "title": "State Values",
        "columns": [
          {"header": "State", "key": "state"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"state": "**PENDING**", "description": "Upload task is queued and waiting to start"},
          {"state": "**PROGRESS**", "description": "File is being processed"},
          {"state": "**SUCCESS**", "description": "Upload completed successfully"},
          {"state": "**FAILURE**", "description": "Upload failed due to an error"}
        ]
      }
    },
    "parameters": [
      {
        "name": "upload_task_id",
        "type": "string",
        "required": true,
        "description": "The upload task ID returned from Upload Tasks endpoint",
        "example": "427a7bfc54cf4ce483d83ba23425164b"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Poll this endpoint periodically until state is SUCCESS or FAILURE before running your squid."
      },
      {
        "type": "note",
        "content": "Check meta.invalid to identify how many rows had issues. Review your CSV format if this number is high."
      },
      {
        "type": "warning",
        "content": "Don't start a squid run until the upload state is SUCCESS, or you may miss tasks."
      }
    ]
  },
  "seo": {
    "title": "Check Upload Status - lobstr.io API Documentation",
    "description": "Learn how to monitor task upload progress using the lobstr.io API."
  }
}
