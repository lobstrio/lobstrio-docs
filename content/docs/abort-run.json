{
  "slug": "abort-run",
  "title": "Abort Run",
  "description": "Stop an active run before completion",
  "category": "Run",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/runs/{run_hash}/abort",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint aborts an active run using its hash ID. The run will stop collecting data and begin the export process for any results already gathered.",
    "sections": {
      "responseFields": {
        "title": "Response Field Explanations",
        "fields": [
          {
            "path": "id",
            "type": "string",
            "description": "The aborted run's identifier",
            "example": "\"300e9c5c127d421c90f431478d9a2cfb\""
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"run\"",
            "example": "\"run\""
          },
          {
            "path": "status",
            "type": "string",
            "description": "Run status (typically \"uploading\" immediately after abort)",
            "example": "\"uploading\""
          },
          {
            "path": "is_done",
            "type": "boolean",
            "description": "Whether the run has fully completed",
            "example": "true"
          },
          {
            "path": "done_reason",
            "type": "string",
            "description": "Will be \"aborted\" for manually stopped runs",
            "example": "\"aborted\""
          },
          {
            "path": "total_results",
            "type": "integer",
            "description": "Number of results collected before abort",
            "example": "6"
          },
          {
            "path": "duration",
            "type": "float",
            "description": "Run duration in seconds before abort",
            "example": "10.4498"
          },
          {
            "path": "credit_used",
            "type": "float",
            "description": "Credits consumed before abort",
            "example": "10.4498"
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "run_hash",
        "type": "string",
        "required": true,
        "description": "The unique identifier (hash) of the run to abort",
        "example": "300e9c5c127d421c90f431478d9a2cfb"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "note",
        "content": "Aborted runs still export any results collected up to the point of abortion."
      },
      {
        "type": "warning",
        "content": "You will still be charged credits for the work done before aborting."
      },
      {
        "type": "tip",
        "content": "Use Get Run Stats to check progress before deciding to abort a run."
      }
    ]
  },
  "seo": {
    "title": "Abort Run - lobstr.io API Documentation",
    "description": "Learn how to abort an active scraping run using the lobstr.io API."
  }
}
