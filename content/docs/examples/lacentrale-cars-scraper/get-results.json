{
  "slug": "examples/lacentrale-cars-scraper/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped LaCentrale vehicle listing data from your squid",
  "category": "Examples",
  "metadata": {
    "method": "GET",
    "endpoint": "/v2/squid/{squid_id}/result",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve vehicle listing data from your completed LaCentrale scraping tasks. The scraper extracts comprehensive vehicle information including pricing, specifications, and seller details.\n\n{{RENDER:basicFields}}\n\n{{RENDER:vehicleFields}}\n\n{{RENDER:sellerFields}}\n\n{{RENDER:deliveryFields}}\n\n{{RENDER:detailFields}}",
    "sections": {
      "basicFields": {
        "title": "Basic Listing Information",
        "fields": [
          {
            "path": "reference",
            "type": "string",
            "description": "Unique listing reference ID",
            "example": "\"W103321695\""
          },
          {
            "path": "listing_url",
            "type": "string",
            "description": "Full URL to the listing",
            "example": "\"https://www.lacentrale.fr/auto-occasion-annonce-87103321695.html\""
          },
          {
            "path": "price",
            "type": "float",
            "description": "Listing price in EUR",
            "example": "34990.0"
          },
          {
            "path": "financing_teasing_price",
            "type": "float",
            "description": "Monthly financing price",
            "example": "493.0"
          },
          {
            "path": "photo_url",
            "type": "string",
            "description": "Main photo URL",
            "example": "\"https://pictures.lacentrale.fr/classifieds/...jpg\""
          },
          {
            "path": "pictures_count",
            "type": "integer",
            "description": "Number of photos",
            "example": "34"
          },
          {
            "path": "first_online_date",
            "type": "datetime",
            "description": "When listing was first published",
            "example": "\"2025-09-26T00:00:00\""
          },
          {
            "path": "good_deal_badge",
            "type": "string",
            "description": "Deal quality indicator",
            "example": "\"VERY_GOOD_DEAL\""
          }
        ]
      },
      "vehicleFields": {
        "title": "Vehicle Information",
        "fields": [
          {
            "path": "make",
            "type": "string",
            "description": "Manufacturer",
            "example": "\"CITROEN\""
          },
          {
            "path": "model",
            "type": "string",
            "description": "Model name",
            "example": "\"JUMPY\""
          },
          {
            "path": "version",
            "type": "string",
            "description": "Full version/trim",
            "example": "\"III CABINE APPROFONDIE TAILLE XL BLUEHDI 180\""
          },
          {
            "path": "year",
            "type": "integer",
            "description": "Model year",
            "example": "2025"
          },
          {
            "path": "mileage",
            "type": "integer",
            "description": "Odometer reading in km",
            "example": "15000"
          },
          {
            "path": "energy",
            "type": "string",
            "description": "Fuel type",
            "example": "\"DIESEL\""
          },
          {
            "path": "gearbox",
            "type": "string",
            "description": "Transmission type",
            "example": "\"AUTO\""
          },
          {
            "path": "doors",
            "type": "integer",
            "description": "Number of doors",
            "example": "5"
          },
          {
            "path": "external_color",
            "type": "string",
            "description": "Exterior color",
            "example": "\"gris metal\""
          },
          {
            "path": "category",
            "type": "string",
            "description": "Vehicle category",
            "example": "\"SUV\""
          }
        ]
      },
      "sellerFields": {
        "title": "Seller Information",
        "fields": [
          {
            "path": "customer_type",
            "type": "string",
            "description": "Seller type (PRO/PARTICULIER)",
            "example": "\"PRO\""
          },
          {
            "path": "contact_name",
            "type": "string",
            "description": "Seller/dealership name",
            "example": "\"LEVELS Automobile\""
          },
          {
            "path": "visit_place",
            "type": "string",
            "description": "Department code",
            "example": "\"59\""
          },
          {
            "path": "country",
            "type": "string",
            "description": "Country code",
            "example": "\"FR\""
          }
        ]
      },
      "deliveryFields": {
        "title": "Delivery Information",
        "fields": [
          {
            "path": "is_deliverable",
            "type": "boolean",
            "description": "Whether delivery is available",
            "example": "true"
          },
          {
            "path": "delivery_price",
            "type": "float",
            "description": "Delivery cost in EUR",
            "example": "819.0"
          },
          {
            "path": "delivery_available_prices",
            "type": "array",
            "description": "Available delivery price tiers",
            "example": "[319, 419, 519, 619, 719, 819]"
          }
        ]
      },
      "detailFields": {
        "title": "Detailed Information (requires annonce_details)",
        "content": "These fields are only populated when `annonce_details` is enabled.",
        "fields": [
          {
            "path": "equipment_list",
            "type": "array",
            "description": "List of standard equipment",
            "example": "[\"ABS\", \"Climatisation\", \"GPS\"]"
          },
          {
            "path": "options_list",
            "type": "array",
            "description": "List of optional equipment",
            "example": "[\"Caméra de recul\", \"Toit panoramique\"]"
          },
          {
            "path": "seller_address",
            "type": "string",
            "description": "Full seller address",
            "example": "\"123 Avenue des Champs-Élysées, 75008, Paris\""
          },
          {
            "path": "seller_name",
            "type": "string",
            "description": "Dealership/seller name",
            "example": "\"KEOS TROYES by Autosphere\""
          },
          {
            "path": "is_verified_seller",
            "type": "boolean",
            "description": "Whether seller is verified",
            "example": "true"
          },
          {
            "path": "co2_emissions",
            "type": "float",
            "description": "CO2 emissions (g/km)",
            "example": "105.0"
          },
          {
            "path": "engine_power_hp",
            "type": "float",
            "description": "Engine power in HP",
            "example": "150.0"
          },
          {
            "path": "fiscal_power",
            "type": "float",
            "description": "Fiscal horsepower",
            "example": "6.0"
          },
          {
            "path": "critair_level",
            "type": "string",
            "description": "Crit'Air sticker level",
            "example": "\"1\""
          },
          {
            "path": "euro_standard",
            "type": "string",
            "description": "Euro emission standard",
            "example": "\"EURO6\""
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "limit",
        "type": "integer",
        "required": false,
        "description": "Number of results per page (default: 10, max: 100)",
        "example": "10"
      },
      {
        "name": "offset",
        "type": "integer",
        "required": false,
        "description": "Number of results to skip for pagination",
        "example": "0"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `good_deal_badge` to identify underpriced vehicles - values include VERY_GOOD_DEAL, GOOD_DEAL."
      },
      {
        "type": "note",
        "content": "The `display_phone` field is base64 encoded. Decode it to get the actual phone number."
      },
      {
        "type": "tip",
        "content": "Filter by `customer_type: PRO` to focus on dealership inventory vs private sellers."
      }
    ]
  },
  "seo": {
    "title": "Get Results - LaCentrale Cars Scraper - lobstr.io API",
    "description": "Learn how to retrieve scraped LaCentrale vehicle listing data using the lobstr.io API."
  },
  "subcategory": "LaCentrale Cars Scraper"
}
