{
  "slug": "examples/tiktok-top-ads-scraper/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped TikTok top ads data",
  "category": "TikTok Top Ads Scraper",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve the scraped TikTok top ads data from your runs. Results include ad details, brand information, engagement metrics, video URLs, and performance data.",
    "sections": {
      "resultFields": {
        "title": "Result Fields",
        "content": "Each result object contains the following fields:",
        "fields": [
          {"path": "internal_id", "type": "string", "description": "Unique identifier for the ad", "example": "\"6916651063119348000\""},
          {"path": "url", "type": "string", "description": "URL to the ad on TikTok Creative Center", "example": "\"https://ads.tiktok.com/business/creativecenter/topads/6916651063119348000\""},
          {"path": "ad_title", "type": "string", "description": "Title or caption of the ad", "example": "\"Don't miss out on our sale before we sell out!\""},
          {"path": "brand_name", "type": "string", "description": "Name of the brand running the ad", "example": "\"GlowSkin\""},
          {"path": "ctr", "type": "float", "description": "Click-through rate of the ad", "example": "0.58"},
          {"path": "industry", "type": "string", "description": "Industry category of the ad", "example": "\"Beauty & Personal Care\""},
          {"path": "objective", "type": "string", "description": "Campaign objective of the ad", "example": "\"Conversion\""},
          {"path": "like", "type": "integer", "description": "Number of likes on the ad", "example": "14523"},
          {"path": "share", "type": "integer", "description": "Number of shares on the ad", "example": "2341"},
          {"path": "comment", "type": "integer", "description": "Number of comments on the ad", "example": "892"},
          {"path": "video_info_duration", "type": "float", "description": "Duration of the video in seconds", "example": "15.016"},
          {"path": "video_info_cover", "type": "string", "description": "URL to the video cover image", "example": "\"https://p16-cc-sign-sg.ibyteimg.com/...\""},
          {"path": "video_info_video_url_720p", "type": "string", "description": "URL to the 720p version of the video", "example": "\"https://v16m-default.akamaized.net/...\""},
          {"path": "video_info_width", "type": "integer", "description": "Video width in pixels", "example": "576"},
          {"path": "video_info_height", "type": "integer", "description": "Video height in pixels", "example": "576"},
          {"path": "keywords", "type": "string", "description": "Keywords associated with the ad", "example": "\"skincare, beauty, sale\""},
          {"path": "landing_page", "type": "string", "description": "Landing page URL for the ad", "example": "\"https://example.com/shop\""},
          {"path": "country_code", "type": "json", "description": "Countries where the ad is shown", "example": "[\"US\", \"CA\", \"GB\"]"},
          {"path": "voice_over", "type": "boolean", "description": "Whether the ad has voice-over", "example": "true"}
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "b6ab0f03b02e472a8e2ab0b16b4fdd0f"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional, filters to that run only)",
        "example": "c29f2f1464ec45d599b1b4f43595bf3a"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Results per page (default: 50, max: 100)",
        "example": "50"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `video_info_video_url_720p` to download the actual ad video for analysis."
      },
      {
        "type": "tip",
        "content": "The `ctr` (click-through rate) field helps identify high-performing ads."
      },
      {
        "type": "note",
        "content": "Video URLs may expire after some time. Download videos promptly if you need to archive them."
      }
    ]
  },
  "seo": {
    "title": "Get Results - TikTok Top Ads Scraper - lobstr.io API",
    "description": "Retrieve scraped TikTok top ads including ad details, engagement metrics, and video information."
  }
}
