{
  "slug": "examples/google-maps-leads-scraper/add-task-params",
  "title": "Add Task Params",
  "description": "Add structured search tasks using city, category, and location parameters",
  "category": "Google Maps Leads Scraper",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/tasks",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Use this format to dynamically define search inputs using structured metadata like city, category, and country. Location values can be obtained from the Get Geolocation endpoint. This method is ideal for automation and scaling across regions.",
    "sections": {
      "taskParams": {
        "title": "Task Parameters",
        "columns": [
          {"header": "Field", "key": "field"},
          {"header": "Type", "key": "type"},
          {"header": "Required", "key": "required"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"field": "**city**", "type": "string", "required": "Yes", "description": "City name with postal code (e.g., `Alpine 91901`)"},
          {"field": "**category**", "type": "string", "required": "Yes", "description": "Business category to search (e.g., `restaurant`)"},
          {"field": "**country**", "type": "string", "required": "No", "description": "Country name (e.g., `United States`)"},
          {"field": "**region**", "type": "string", "required": "No", "description": "State or province (e.g., `California`)"},
          {"field": "**district**", "type": "string", "required": "No", "description": "County or local district (e.g., `San Diego`)"}
        ]
      },
      "requestBody": {
        "title": "Request Body",
        "columns": [
          {"header": "Field", "key": "field"},
          {"header": "Type", "key": "type"},
          {"header": "Required", "key": "required"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"field": "**squid**", "type": "string", "required": "Yes", "description": "Hash of your squid configured with the google-maps-leads-scraper crawler"},
          {"field": "**tasks**", "type": "array", "required": "Yes", "description": "Array of task objects with location parameters"}
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use the Get Geolocation endpoint to fetch valid values for city, region, and district."
      },
      {
        "type": "note",
        "content": "The `city` field must include the postal code (e.g., `Anaheim 92801`)."
      }
    ]
  },
  "seo": {
