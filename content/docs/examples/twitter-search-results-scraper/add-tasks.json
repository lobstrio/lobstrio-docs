{
  "slug": "examples/twitter-search-results-scraper/add-tasks",
  "title": "Add Tasks",
  "description": "Add Twitter search scraping tasks by providing search URLs",
  "category": "Twitter Search Results Scraper",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/tasks",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Add Twitter search results to scrape by providing search URLs from X.com (Twitter). The scraper will extract tweets matching your search query.",
    "sections": {
      "requestBody": {
        "title": "Request Body",
        "columns": [
          {"header": "Field", "key": "field"},
          {"header": "Type", "key": "type"},
          {"header": "Required", "key": "required"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"field": "**squid**", "type": "string", "required": "Yes", "description": "Hash of your squid configured with the Twitter Search Results Scraper"},
          {"field": "**tasks**", "type": "array", "required": "Yes", "description": "Array of task objects, each containing a `url` field"}
        ]
      },
      "taskObject": {
        "title": "Task Object",
        "columns": [
          {"header": "Field", "key": "field"},
          {"header": "Type", "key": "type"},
          {"header": "Required", "key": "required"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"field": "**url**", "type": "string", "required": "Yes", "description": "Twitter search URL (e.g., `https://x.com/search?q=keyword&src=typed_query&f=top`)"}
        ]
      },
      "searchUrlParams": {
        "title": "Search URL Parameters",
        "content": "Twitter search URLs support various filters via query parameters:",
        "columns": [
          {"header": "Parameter", "key": "param"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"param": "**q**", "description": "Search query (URL encoded)"},
          {"param": "**f=top**", "description": "Show top results"},
          {"param": "**f=live**", "description": "Show latest results"},
          {"param": "**f=user**", "description": "Show people results"},
          {"param": "**f=image**", "description": "Show image results"},
          {"param": "**f=video**", "description": "Show video results"}
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Perform your search on Twitter/X first, apply filters, then copy the URL to preserve all search parameters."
      },
      {
        "type": "tip",
        "content": "Use `f=live` to get the most recent tweets matching your query."
      },
      {
        "type": "note",
        "content": "Advanced search operators like `from:username`, `since:2024-01-01`, and `filter:media` are supported in the query."
      }
