{
  "slug": "examples/seloger-search-export/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped SeLoger real estate listings",
  "category": "Examples",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve scraped SeLoger real estate listings including property details, pricing, location, agency information, and energy performance ratings.",
    "sections": {
      "coreFields": {
        "title": "Core Result Fields",
        "content": "Standard result identifiers:",
        "fields": [
          {
            "path": "id",
            "type": "integer",
            "description": "Unique result identifier",
            "example": "7779945"
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"result\"",
            "example": "\"result\""
          },
          {
            "path": "squid",
            "type": "string",
            "description": "Squid that produced this result",
            "example": "\"e23069fee2594ee0aed755be195b156c\""
          },
          {
            "path": "run",
            "type": "string",
            "description": "Run that produced this result",
            "example": "\"6ecdfb8a43c841d18502f045200196f7\""
          },
          {
            "path": "annonce_id",
            "type": "integer",
            "description": "Unique SeLoger listing identifier",
            "example": "246281705"
          }
        ]
      },
      "propertyFields": {
        "title": "Property Information",
        "content": "Basic property details:",
        "fields": [
          {
            "path": "title",
            "type": "string",
            "description": "Headline/title of the listing",
            "example": "\"Appartement 3 pièces 75m²\""
          },
          {
            "path": "description",
            "type": "string",
            "description": "Full listing description",
            "example": "\"Bel appartement lumineux...\""
          },
          {
            "path": "short_description",
            "type": "string",
            "description": "Brief excerpt of the listing",
            "example": "\"Appartement à vendre...\""
          },
          {
            "path": "url",
            "type": "string",
            "description": "Direct link to the listing",
            "example": "\"https://www.seloger.com/annonces/achat/...\""
          },
          {
            "path": "estate_type",
            "type": "string",
            "description": "Type of property",
            "example": "\"Appartement\""
          },
          {
            "path": "estate_type_id",
            "type": "integer",
            "description": "Numeric code for estate type",
            "example": "2"
          },
          {
            "path": "area",
            "type": "number",
            "description": "Surface area in square meters",
            "example": "75.5"
          },
          {
            "path": "rooms",
            "type": "integer | null",
            "description": "Number of rooms",
            "example": "3"
          },
          {
            "path": "bedrooms_count",
            "type": "integer | null",
            "description": "Number of bedrooms",
            "example": "2"
          },
          {
            "path": "is_furnished",
            "type": "boolean",
            "description": "Whether furnished",
            "example": "false"
          },
          {
            "path": "features",
            "type": "string | null",
            "description": "Key features/amenities",
            "example": "\"Balcon, Parking\""
          }
        ]
      },
      "pricingFields": {
        "title": "Pricing Information",
        "content": "Price and transaction details:",
        "fields": [
          {
            "path": "price",
            "type": "number",
            "description": "Total listing price in euros",
            "example": "350000"
          },
          {
            "path": "monthly_price",
            "type": "number",
            "description": "Monthly rent/price in euros",
            "example": "1200"
          },
          {
            "path": "price_per_meter",
            "type": "number | null",
            "description": "Price per square meter",
            "example": "4666"
          },
          {
            "path": "transaction_type",
            "type": "integer",
            "description": "Transaction type code (1=rent, 2=sale)",
            "example": "2"
          },
          {
            "path": "nature",
            "type": "integer",
            "description": "Transaction nature code",
            "example": "1"
          }
        ]
      },
      "locationFields": {
        "title": "Location Information",
        "content": "Geographic details:",
        "fields": [
          {
            "path": "address",
            "type": "string",
            "description": "Town or locality name",
            "example": "\"Paris 15ème\""
          },
          {
            "path": "postal_code",
            "type": "string",
            "description": "Postal code",
            "example": "\"75015\""
          },
          {
            "path": "district",
            "type": "string | null",
            "description": "District or arrondissement",
            "example": "\"15ème\""
          },
          {
            "path": "insee_code",
            "type": "string | null",
            "description": "INSEE code for French municipalities",
            "example": "\"75115\""
          },
          {
            "path": "latitude",
            "type": "number",
            "description": "Geographic latitude",
            "example": "48.8456"
          },
          {
            "path": "longitude",
            "type": "number",
            "description": "Geographic longitude",
            "example": "2.2892"
          }
        ]
      },
      "agencyFields": {
        "title": "Agency Information",
        "content": "Real estate agency details:",
        "fields": [
          {
            "path": "agency_contact_name",
            "type": "string",
            "description": "Name of the agency contact",
            "example": "\"Agence Immobilière Paris\""
          },
          {
            "path": "agency_id",
            "type": "integer",
            "description": "Internal SeLoger agency ID",
            "example": "519049"
          },
          {
            "path": "agency_phone_number",
            "type": "string",
            "description": "Agency contact phone",
            "example": "\"01 23 45 67 89\""
          },
          {
            "path": "agency_has_email",
            "type": "boolean",
            "description": "Whether agency email is available",
            "example": "true"
          },
          {
            "path": "agency_page",
            "type": "string",
            "description": "URL of agency's SeLoger page",
            "example": "\"https://www.seloger.com/professionnels/...\""
          },
          {
            "path": "agency_img_url",
            "type": "string | null",
            "description": "Agency logo URL",
            "example": "\"https://...\""
          },
          {
            "path": "agency_link",
            "type": "string | null",
            "description": "External agency website",
            "example": "\"https://www.agence.fr\""
          },
          {
            "path": "contact_is_private_seller",
            "type": "boolean",
            "description": "True if private seller (not agency)",
            "example": "false"
          },
          {
            "path": "contact_email",
            "type": "boolean",
            "description": "Whether contact email is provided",
            "example": "true"
          }
        ]
      },
      "energyFields": {
        "title": "Energy Performance",
        "content": "DPE and GES ratings (French energy diagnostics):",
        "fields": [
          {
            "path": "dpe",
            "type": "string | null",
            "description": "Energy Performance Diagnostic rating (A-G)",
            "example": "\"C\""
          },
          {
            "path": "ges",
            "type": "string | null",
            "description": "Greenhouse Gas rating (A-G)",
            "example": "\"D\""
          },
          {
            "path": "electricity_consumption",
            "type": "string | null",
            "description": "Electricity consumption metric",
            "example": "\"150 kWh/m²/an\""
          },
          {
            "path": "gas_emissions",
            "type": "string | null",
            "description": "Greenhouse gas emissions rating",
            "example": "\"25 kg CO2/m²/an\""
          }
        ]
      },
      "coownershipFields": {
        "title": "Co-ownership Details",
        "content": "For properties in co-ownership (copropriété):",
        "fields": [
          {
            "path": "coownership_annual_charges",
            "type": "number | null",
            "description": "Annual co-ownership charges",
            "example": "2400"
          },
          {
            "path": "coownership_number_of_lots",
            "type": "integer | null",
            "description": "Total lots in co-ownership",
            "example": "50"
          },
          {
            "path": "coownership_is_syndic_procedure",
            "type": "boolean",
            "description": "Under syndic procedure",
            "example": "false"
          }
        ]
      },
      "mediaFields": {
        "title": "Media & Images",
        "content": "Listing images and virtual tours:",
        "fields": [
          {
            "path": "main_picture",
            "type": "string",
            "description": "URL of main listing image",
            "example": "\"https://mms.seloger.com/...\""
          },
          {
            "path": "pictures",
            "type": "string",
            "description": "Comma-separated thumbnail URLs",
            "example": "\"url1, url2, url3\""
          },
          {
            "path": "additional_pictures",
            "type": "string",
            "description": "Comma-separated full-size image URLs",
            "example": "\"url1, url2, url3\""
          },
          {
            "path": "picture_count",
            "type": "integer",
            "description": "Total number of pictures",
            "example": "8"
          },
          {
            "path": "video_url",
            "type": "string | null",
            "description": "Video tour URL",
            "example": "\"https://...\""
          },
          {
            "path": "virtual_visit_url",
            "type": "string | null",
            "description": "3D virtual visit URL",
            "example": "\"https://...\""
          }
        ]
      },
      "statusFields": {
        "title": "Listing Status",
        "content": "Status and highlighting:",
        "fields": [
          {
            "path": "is_exclusive",
            "type": "boolean",
            "description": "Exclusive listing",
            "example": "false"
          },
          {
            "path": "is_expired",
            "type": "boolean",
            "description": "Listing has expired",
            "example": "false"
          },
          {
            "path": "highlighting_level",
            "type": "integer",
            "description": "Prominence level (higher = more featured)",
            "example": "3"
          },
          {
            "path": "tags",
            "type": "string | null",
            "description": "Highlight tags",
            "example": "\"75 m²\""
          },
          {
            "path": "publication_id",
            "type": "string",
            "description": "Internal publication ID",
            "example": "\"30519049\""
          }
        ]
      },
      "timestampFields": {
        "title": "Timestamps",
        "fields": [
          {
            "path": "scraping_time",
            "type": "string",
            "description": "When scraped (ISO 8601)",
            "example": "\"2025-07-16T10:04:14.545Z\""
          },
          {
            "path": "last_scraping_time",
            "type": "string | null",
            "description": "Previous scraping time",
            "example": "null"
          },
          {
            "path": "functions.annonce_details.filling_date",
            "type": "string",
            "description": "When detail enrichment ran",
            "example": "\"07/16/2025, 08:40:50 +0200\""
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "e23069fee2594ee0aed755be195b156c"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional)",
        "example": "6ecdfb8a43c841d18502f045200196f7"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Results per page (default: 50, max: 100)",
        "example": "50"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `latitude` and `longitude` fields (available when `annonce_details` is enabled) to plot properties on a map."
      },
      {
        "type": "tip",
        "content": "Filter by `transaction_type`: 1 for rentals, 2 for sales."
      },
      {
        "type": "note",
        "content": "DPE/GES ratings follow French energy diagnostic standards (A = most efficient, G = least efficient)."
      }
    ]
  },
  "seo": {
    "title": "Get Results - SeLoger Search Export - lobstr.io API",
    "description": "Retrieve SeLoger real estate listings using the lobstr.io API."
  },
  "subcategory": "SeLoger Search Export"
}
