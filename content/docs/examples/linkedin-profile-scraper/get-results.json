{
  "slug": "examples/linkedin-profile-scraper/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped LinkedIn profile data from your squid",
  "category": "LinkedIn Profile Scraper",
  "metadata": {
    "method": "GET",
    "endpoint": "/v2/squid/{squid_id}/result",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve comprehensive LinkedIn profile data from your completed scraping tasks. The scraper extracts detailed information including work history, education, skills, and optionally email addresses.\n\n{{RENDER:profileFields}}\n\n{{RENDER:emailFields}}\n\n{{RENDER:connectionFields}}\n\n{{RENDER:jobFields}}\n\n{{RENDER:educationFields}}\n\n{{RENDER:skillsInterestsFields}}\n\n{{RENDER:featuredFields}}",
    "sections": {
      "profileFields": {
        "title": "Profile Information Fields",
        "fields": [
          { "path": "url", "type": "string", "description": "LinkedIn profile URL", "example": "\"https://www.linkedin.com/in/williamhgates/\"" },
          { "path": "public_identifier", "type": "string", "description": "LinkedIn username/identifier", "example": "\"williamhgates\"" },
          { "path": "first_name", "type": "string", "description": "First name", "example": "\"Bill\"" },
          { "path": "last_name", "type": "string", "description": "Last name", "example": "\"Gates\"" },
          { "path": "full_name", "type": "string", "description": "Full display name", "example": "\"Bill Gates\"" },
          { "path": "headline", "type": "string", "description": "Profile headline", "example": "\"Co-chair, Bill & Melinda Gates Foundation\"" },
          { "path": "description", "type": "string", "description": "Profile summary/about section", "example": "\"Co-chair of the Bill & Melinda Gates Foundation...\"" },
          { "path": "location", "type": "string", "description": "Location from profile", "example": "\"Seattle, Washington, United States\"" },
          { "path": "industry", "type": "string", "description": "Industry", "example": "\"Philanthropy\"" },
          { "path": "vmid", "type": "string", "description": "LinkedIn internal member ID", "example": "\"ACoAAA8BYqEBCGLg_vT_ca6mMEqkpp9nVffJ3hc\"" },
          { "path": "sales_nav_url", "type": "string", "description": "Sales Navigator profile URL", "example": "\"https://www.linkedin.com/sales/people/ACoAAA8BYqE\"" },
          { "path": "picture_url", "type": "string", "description": "Profile picture URL", "example": "\"https://media.licdn.com/dms/image/...\"" },
          { "path": "background_picture_url", "type": "string", "description": "Background/banner image URL", "example": "\"https://media.licdn.com/dms/image/...\"" },
          { "path": "is_creator", "type": "string", "description": "Whether profile has creator mode enabled", "example": "\"True\"" },
          { "path": "open_to_work", "type": "boolean", "description": "Whether profile shows open to work status", "example": "false" },
          { "path": "num_connections", "type": "integer", "description": "Number of connections (500+ shows as 500)", "example": "500" },
          { "path": "num_followers", "type": "integer", "description": "Number of followers", "example": "35421987" }
        ]
      },
      "emailFields": {
        "title": "Email Enrichment Fields",
        "content": "These fields are only populated when email enrichment is enabled.",
        "fields": [
          { "path": "email", "type": "string", "description": "Discovered email address (if found)", "example": "\"contact@example.com\"" },
          { "path": "email_status", "type": "string", "description": "Email validation status: valid, invalid, catch-all, unknown", "example": "\"valid\"" }
        ]
      },
      "connectionFields": {
        "title": "Connection Fields",
        "fields": [
          { "path": "connection_degree", "type": "string", "description": "Connection degree (1st, 2nd, 3rd)", "example": "\"2\"" },
          { "path": "connections_url", "type": "string", "description": "URL to view profile's connections", "example": "\"https://www.linkedin.com/search/results/people/?...\"" },
          { "path": "mutual_connections_url", "type": "string", "description": "URL to view mutual connections", "example": "\"https://www.linkedin.com/search/results/people/?...\"" },
          { "path": "mutual_connections_text", "type": "string", "description": "Text showing number of mutual connections", "example": "\"15 mutual connections\"" }
        ]
      },
      "jobFields": {
        "title": "Work Experience Fields",
        "content": "Job history is available in two formats: as a `jobs` array or as individual fields `job_1` through `job_10`.\n\n**Jobs Array Format:**\nEach job object contains: `title`, `description`, `location`, `company_name`, `company_url`, `company_logo`, `start_year`, `start_month`, `end_year`, `end_month`.\n\n**Individual Job Fields:**\nFor each job (1-10), the following flattened fields are available:",
        "fields": [
          { "path": "jobs", "type": "array", "description": "Array of job objects with full details", "example": "[{\"title\": \"CEO\", \"company_name\": \"Microsoft\", ...}]" },
          { "path": "job_1", "type": "object", "description": "First job as JSON object", "example": "{\"title\": \"Co-chair\", \"company_name\": \"Bill & Melinda Gates Foundation\"}" },
          { "path": "job_1_title", "type": "string", "description": "Job title", "example": "\"Co-chair\"" },
          { "path": "job_1_company_name", "type": "string", "description": "Company name", "example": "\"Bill & Melinda Gates Foundation\"" },
          { "path": "job_1_company_url", "type": "string", "description": "LinkedIn company page URL", "example": "\"https://www.linkedin.com/company/8736/\"" },
          { "path": "job_1_company_logo", "type": "string", "description": "Company logo URL", "example": "\"https://media.licdn.com/dms/image/...\"" },
          { "path": "job_1_location", "type": "string", "description": "Job location", "example": "\"Seattle, Washington, United States\"" },
          { "path": "job_1_description", "type": "string", "description": "Job description text", "example": "\"Leading global health and education initiatives...\"" },
          { "path": "job_1_start_year", "type": "integer", "description": "Start year", "example": "2000" },
          { "path": "job_1_start_month", "type": "integer", "description": "Start month (1-12)", "example": "1" },
          { "path": "job_1_end_year", "type": "integer", "description": "End year (null if current)", "example": "null" },
          { "path": "job_1_end_month", "type": "integer", "description": "End month (null if current)", "example": "null" }
        ]
      },
      "educationFields": {
        "title": "Education Fields",
        "content": "Education history is available as an `educations` array or as individual fields `education_1` through `education_10`.\n\nEach education entry contains: `school_name`, `field_of_study`, `description`, `grade`, `activities`, `school_logo`, `school_urn`, `start_year`, `end_year`.",
        "fields": [
          { "path": "educations", "type": "array", "description": "Array of education objects", "example": "[{\"school_name\": \"Harvard University\", \"field_of_study\": \"Computer Science\"}]" },
          { "path": "education_1", "type": "object", "description": "First education entry as JSON object", "example": "{\"school_name\": \"Harvard University\", ...}" }
        ]
      },
      "skillsInterestsFields": {
        "title": "Skills & Interests Fields",
        "fields": [
          { "path": "skills", "type": "array", "description": "List of skills from profile", "example": "[\"Strategic Planning\", \"Leadership\", \"Public Speaking\"]" },
          { "path": "interests_companies", "type": "array", "description": "Companies the user follows", "example": "[{\"company_id\": \"123\", \"company_name\": \"Microsoft\", ...}]" },
          { "path": "interests_groups", "type": "array", "description": "Groups the user is a member of", "example": "[{\"group_id\": \"456\", \"group_name\": \"Tech Leaders\", ...}]" }
        ]
      },
      "featuredFields": {
        "title": "Featured Posts Fields",
        "content": "Up to 5 featured posts are extracted from the profile's Featured section.",
        "fields": [
          { "path": "featured_1", "type": "object", "description": "First featured post with URL, likes, comments, and text", "example": "{\"post_url\": \"https://linkedin.com/feed/...\", \"num_likes\": 156, \"text\": \"...\"}" },
          { "path": "featured_2", "type": "object", "description": "Second featured post", "example": "{}" },
          { "path": "featured_3", "type": "object", "description": "Third featured post", "example": "{}" },
          { "path": "featured_4", "type": "object", "description": "Fourth featured post", "example": "{}" },
          { "path": "featured_5", "type": "object", "description": "Fifth featured post", "example": "{}" }
        ]
      }
    },
    "parameters": [
      {
        "name": "limit",
        "type": "integer",
        "required": false,
        "description": "Number of results per page (default: 10, max: 100)",
        "example": "10"
      },
      {
        "name": "offset",
        "type": "integer",
        "required": false,
        "description": "Number of results to skip for pagination",
        "example": "0"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use the `jobs` array for easier processing, or use flattened fields like `job_1_title` for direct access to specific positions."
      },
      {
        "type": "note",
        "content": "The scraper extracts up to 10 jobs and 10 education entries per profile."
      },
      {
        "type": "tip",
        "content": "Check `open_to_work` to identify candidates actively seeking new opportunities."
      },
      {
        "type": "note",
        "content": "Email fields are only populated when email enrichment is enabled in settings."
      }
    ]
  },
  "seo": {
    "title": "Get Results - LinkedIn Profile Scraper - lobstr.io API",
    "description": "Learn how to retrieve scraped LinkedIn profile data including work history, education, skills, and email addresses using the lobstr.io API."
  }
}
