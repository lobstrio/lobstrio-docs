{
  "slug": "examples/twitter-profile-scraper/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Twitter profile data",
  "category": "Twitter Profile Scraper",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve scraped Twitter profile data. Each result contains detailed profile information including follower counts, verification status, and profile metadata.",
    "sections": {
      "coreFields": {
        "title": "Core Result Fields",
        "content": "Standard result identifiers:",
        "fields": [
          {"path": "id", "type": "integer", "description": "Unique result identifier", "example": "53557759"},
          {"path": "object", "type": "string", "description": "Always \"result\"", "example": "\"result\""},
          {"path": "squid", "type": "string", "description": "Squid that produced this result", "example": "\"72d18e4c94534b829877bb7c092b1f80\""},
          {"path": "run", "type": "string", "description": "Run that produced this result", "example": "\"3ff48bb8ef19426e87fbb3e102dd4531\""},
          {"path": "_json", "type": "string", "description": "Raw JSON payload from Twitter's API (if json=true)", "example": "\"{...}\""}
        ]
      },
      "profileFields": {
        "title": "Profile Information",
        "content": "User profile details:",
        "fields": [
          {"path": "name", "type": "string", "description": "Display name of the user", "example": "\"Elon Musk\""},
          {"path": "screen_name", "type": "string", "description": "User's handle without the @ symbol", "example": "\"elonmusk\""},
          {"path": "bio", "type": "string", "description": "User's profile biography text", "example": "\"Mars & Cars...\""},
          {"path": "location", "type": "string", "description": "User-specified location", "example": "\"Mars\""},
          {"path": "website", "type": "string", "description": "URL of the user's website", "example": "\"https://tesla.com\""},
          {"path": "created_at", "type": "string", "description": "Account creation timestamp (ISO 8601)", "example": "\"2009-06-02T20:12:29Z\""},
          {"path": "internal_id", "type": "string", "description": "Twitter's internal user identifier", "example": "\"44196397\""}
        ]
      },
      "metricsFields": {
        "title": "Engagement Metrics",
        "content": "Follower and activity counts:",
        "fields": [
          {"path": "followers_count", "type": "integer", "description": "Total number of followers", "example": "150000000"},
          {"path": "following_count", "type": "integer", "description": "Number of accounts the user follows", "example": "500"},
          {"path": "posts_count", "type": "integer", "description": "Total number of tweets posted", "example": "25000"},
          {"path": "favourites_count", "type": "integer", "description": "Total tweets favorited", "example": "15000"},
          {"path": "listed_count", "type": "integer", "description": "Number of public lists user appears in", "example": "50000"},
          {"path": "media_count", "type": "integer", "description": "Number of media items tweeted", "example": "1000"}
        ]
      },
      "verificationFields": {
        "title": "Verification & Status",
        "content": "Account verification and subscription status:",
        "fields": [
          {"path": "is_blue_verified", "type": "boolean", "description": "True if the account is Blue Verified", "example": "true"},
          {"path": "possibly_sensitive", "type": "boolean", "description": "True if content is potentially sensitive", "example": "false"},
          {"path": "super_follow_eligible", "type": "boolean", "description": "True if eligible for Super Follows", "example": "true"},
          {"path": "creator_subscriptions_count", "type": "integer", "description": "Number of creator subscriptions", "example": "0"}
        ]
      },
      "imageFields": {
        "title": "Profile Images",
        "content": "Profile and banner image URLs:",
        "fields": [
          {"path": "profile_image_url_https", "type": "string", "description": "HTTPS URL of the profile image", "example": "\"https://pbs.twimg.com/...\""},
          {"path": "profile_banner_url", "type": "string", "description": "URL of the profile banner image", "example": "\"https://pbs.twimg.com/...\""},
          {"path": "profile_image_shape", "type": "string", "description": "Shape setting for profile image", "example": "\"Circle\""}
        ]
      },
      "timestampFields": {
        "title": "Timestamps",
        "fields": [
          {"path": "scraping_time", "type": "string", "description": "When this profile was scraped (ISO 8601)", "example": "\"2025-07-04T04:08:09.340Z\""}
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "72d18e4c94534b829877bb7c092b1f80"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional)",
        "example": "3ff48bb8ef19426e87fbb3e102dd4531"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Results per page (default: 50, max: 100)",
        "example": "50"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `is_blue_verified` to identify verified accounts in your results."
      },
      {
        "type": "tip",
        "content": "The `_json` field contains the complete raw API response when `json=true` is set in settings."
      },
      {
        "type": "note",
        "content": "Some fields like `website` may be empty if the user hasn't provided that information."
      }
    ]
  },
  "seo": {
    "title": "Get Results - Twitter Profile Scraper - lobstr.io API",
    "description": "Retrieve Twitter profile data using the lobstr.io API."
  }
}
