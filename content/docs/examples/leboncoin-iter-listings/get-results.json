{
  "slug": "examples/leboncoin-iter-listings/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Leboncoin listings with details and seller information",
  "category": "Examples",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve scraped classified listings from Leboncoin including pricing, location, seller details, and property-specific fields like DPE/GES ratings.",
    "sections": {
      "listingFields": {
        "title": "Listing Information",
        "content": "Core listing details:",
        "fields": [
          {
            "path": "id",
            "type": "integer",
            "description": "Unique result identifier",
            "example": "53557759"
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"result\"",
            "example": "\"result\""
          },
          {
            "path": "squid",
            "type": "string",
            "description": "Squid that produced this result",
            "example": "\"72d18e4c94534b829877bb7c092b1f80\""
          },
          {
            "path": "run",
            "type": "string",
            "description": "Run that produced this result",
            "example": "\"3ff48bb8ef19426e87fbb3e102dd4531\""
          },
          {
            "path": "title",
            "type": "string",
            "description": "Listing title/headline",
            "example": "\"Chaise de bureau\""
          },
          {
            "path": "description",
            "type": "string",
            "description": "Full listing description",
            "example": "\"Je vends chaise de bureau...\""
          },
          {
            "path": "price",
            "type": "integer",
            "description": "Listing price",
            "example": "20"
          },
          {
            "path": "currency",
            "type": "string",
            "description": "Currency code",
            "example": "\"EUR\""
          },
          {
            "path": "url",
            "type": "string",
            "description": "Direct URL to the listing",
            "example": "\"https://www.leboncoin.fr/ad/...\""
          },
          {
            "path": "annonce_id",
            "type": "string",
            "description": "Leboncoin listing ID",
            "example": "\"3017342920\""
          },
          {
            "path": "category_name",
            "type": "string",
            "description": "Category of the listing",
            "example": "\"Ameublement\""
          },
          {
            "path": "ad_type",
            "type": "string",
            "description": "Type of ad (offer/search)",
            "example": "\"offer\""
          }
        ]
      },
      "locationFields": {
        "title": "Location Information",
        "content": "Geographic details:",
        "fields": [
          {
            "path": "city",
            "type": "string",
            "description": "City name",
            "example": "\"Aix-en-Provence\""
          },
          {
            "path": "city_label",
            "type": "string",
            "description": "City with postal code",
            "example": "\"Aix-en-Provence 13100\""
          },
          {
            "path": "postal_code",
            "type": "string",
            "description": "Postal code",
            "example": "\"13100\""
          },
          {
            "path": "department",
            "type": "string",
            "description": "French department",
            "example": "\"Bouches-du-Rhône\""
          },
          {
            "path": "region",
            "type": "string",
            "description": "Region name",
            "example": "\"Provence-Alpes-Côte d'Azur\""
          },
          {
            "path": "lat",
            "type": "string",
            "description": "Latitude coordinate",
            "example": "\"43.52638\""
          },
          {
            "path": "lng",
            "type": "string",
            "description": "Longitude coordinate",
            "example": "\"5.44614\""
          }
        ]
      },
      "sellerFields": {
        "title": "Seller Information",
        "content": "Details about the seller:",
        "fields": [
          {
            "path": "owner_name",
            "type": "string",
            "description": "Seller's display name",
            "example": "\"EMMA\""
          },
          {
            "path": "owner_type",
            "type": "string",
            "description": "Seller type code",
            "example": "\"0\""
          },
          {
            "path": "owner_store_id",
            "type": "string",
            "description": "Seller's store ID",
            "example": "\"1095173\""
          },
          {
            "path": "owner_siren",
            "type": "string | null",
            "description": "Business SIREN number",
            "example": "null"
          },
          {
            "path": "has_phone",
            "type": "boolean",
            "description": "Whether phone is available",
            "example": "false"
          },
          {
            "path": "has_online_shop",
            "type": "boolean",
            "description": "Whether seller has shop URL",
            "example": "false"
          },
          {
            "path": "online_shop_url",
            "type": "string | null",
            "description": "Seller's shop URL",
            "example": "null"
          }
        ]
      },
      "propertyFields": {
        "title": "Real Estate Fields",
        "content": "Property-specific fields (when applicable):",
        "fields": [
          {
            "path": "DPE",
            "type": "string | null",
            "description": "Energy Performance rating (A-G)",
            "example": "\"C\""
          },
          {
            "path": "DPE_int",
            "type": "integer | null",
            "description": "Numeric DPE value",
            "example": "3"
          },
          {
            "path": "GES",
            "type": "string | null",
            "description": "Greenhouse Gas rating (A-G)",
            "example": "\"B\""
          },
          {
            "path": "GES_int",
            "type": "integer | null",
            "description": "Numeric GES value",
            "example": "2"
          },
          {
            "path": "area",
            "type": "string | null",
            "description": "Property area (sqm)",
            "example": "\"75\""
          },
          {
            "path": "room_count",
            "type": "integer | null",
            "description": "Number of rooms",
            "example": "3"
          },
          {
            "path": "real_estate_type",
            "type": "string | null",
            "description": "Property type",
            "example": "\"apartment\""
          },
          {
            "path": "furnished",
            "type": "boolean | null",
            "description": "Whether furnished",
            "example": "false"
          },
          {
            "path": "price_per_square_meter",
            "type": "number | null",
            "description": "Price per sqm",
            "example": "4500.5"
          }
        ]
      },
      "mediaFields": {
        "title": "Media & Status",
        "content": "Images and listing status:",
        "fields": [
          {
            "path": "picture",
            "type": "string",
            "description": "Primary image URL",
            "example": "\"https://img.leboncoin.fr/...\""
          },
          {
            "path": "pictures",
            "type": "string",
            "description": "Comma-separated image URLs",
            "example": "\"url1, url2, url3\""
          },
          {
            "path": "first_publication_date",
            "type": "string",
            "description": "When first published (ISO)",
            "example": "\"2025-07-04T04:05:30Z\""
          },
          {
            "path": "last_publication_date",
            "type": "string",
            "description": "When last updated (ISO)",
            "example": "\"2025-07-04T04:05:30Z\""
          },
          {
            "path": "urgent",
            "type": "boolean",
            "description": "Marked as urgent",
            "example": "false"
          },
          {
            "path": "booster",
            "type": "boolean",
            "description": "Listing is boosted",
            "example": "false"
          },
          {
            "path": "scraping_time",
            "type": "string",
            "description": "When scraped (ISO)",
            "example": "\"2025-07-04T04:08:09.340Z\""
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "72d18e4c94534b829877bb7c092b1f80"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional)",
        "example": "3ff48bb8ef19426e87fbb3e102dd4531"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Results per page (default: 50, max: 100)",
        "example": "50"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "The `details` object contains structured attributes that vary by category (furniture type, condition, color, etc.)."
      },
      {
        "type": "tip",
        "content": "Use `first_publication_date` to filter for new listings when processing results."
      },
      {
        "type": "note",
        "content": "DPE/GES fields are only populated for real estate listings."
      }
    ]
  },
  "seo": {
    "title": "Get Results - Leboncoin Listings Search Export - lobstr.io API",
    "description": "Retrieve Leboncoin classified listings with pricing and seller data using the lobstr.io API."
  },
  "subcategory": "Leboncoin Listings Search Export"
}
