{
  "slug": "examples/leboncoin-iter-listings/update-settings",
  "title": "Update Settings",
  "description": "Configure scraper settings for Leboncoin Listings Search Export",
  "category": "Examples",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/squids/{squid_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Configure your squid settings for the Leboncoin Listings Search Export scraper. Control pagination, time filters, and optional shop URL extraction.",
    "sections": {
      "scraperParams": {
        "title": "Scraper Parameters",
        "content": "Set these parameters in the `params` object:",
        "columns": [
          {
            "header": "Parameter",
            "key": "param"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Default",
            "key": "default"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "param": "**max_date**",
            "type": "string (ISO) | null",
            "default": "null",
            "description": "Deprecated. Use `fetch_since` instead"
          },
          {
            "param": "**fetch_since**",
            "type": "string",
            "default": "null",
            "description": "Only collect items published after this point. Use a relative duration (24h, 7d, 2w) or an absolute date (YYYY-MM-DD)"
          },
          {
            "param": "**hours_back**",
            "type": "integer | null",
            "default": "null",
            "description": "Deprecated. Use `fetch_since` instead"
          },
          {
            "param": "**max_pages**",
            "type": "integer",
            "default": "null",
            "description": "Maximum number of result pages to crawl"
          },
          {
            "param": "**max_results**",
            "type": "integer",
            "default": "null",
            "description": "Total number of listings to collect before stopping"
          },
          {
            "param": "**online_shop**",
            "type": "boolean",
            "default": "false",
            "description": "Extract seller's shop URL (incurs extra requests/credits)"
          }
        ]
      },
      "squidSettings": {
        "title": "Squid Settings",
        "content": "Configure general squid settings:",
        "columns": [
          {
            "header": "Setting",
            "key": "setting"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "setting": "**name**",
            "type": "string",
            "description": "Display name for your squid configuration"
          },
          {
            "setting": "**concurrency**",
            "type": "integer",
            "description": "Number of parallel scraping workers (default: 1)"
          },
          {
            "setting": "**export_unique_results**",
            "type": "boolean",
            "description": "Export only unique results (deduplicated)"
          },
          {
            "setting": "**to_complete**",
            "type": "boolean",
            "description": "Run until all tasks complete"
          },
          {
            "setting": "**no_line_breaks**",
            "type": "boolean",
            "description": "Remove line breaks from results"
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `fetch_since` to monitor new listings - set to `24` to only collect listings from the last day."
      },
      {
        "type": "warning",
        "content": "Enabling `online_shop` adds extra requests per listing and increases credit consumption."
      },
      {
        "type": "note",
        "content": "If both `fetch_since` and `fetch_since` are set, `fetch_since` takes priority."
      }
    ]
  },
  "seo": {
    "title": "Update Settings - Leboncoin Listings Search Export - lobstr.io API",
    "description": "Configure Leboncoin Listings Search Export scraper settings using the lobstr.io API."
  },
