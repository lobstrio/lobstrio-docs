{
  "slug": "examples/google-news-search-export/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Google News articles",
  "category": "Google News Search Export",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve the scraped news articles from your Google News Search Export runs. Each result represents one news article with its title, source, publication date, and more.",
    "sections": {
      "resultFields": {
        "title": "Result Fields",
        "content": "Each result object contains the following fields:",
        "fields": [
          {"path": "id", "type": "integer", "description": "Unique identifier for this result", "example": "818292"},
          {"path": "object", "type": "string", "description": "Always \"result\"", "example": "\"result\""},
          {"path": "squid", "type": "string", "description": "Hash ID of the squid that produced this result", "example": "\"daf6d92ae704469196a14891d8f4b3fd\""},
          {"path": "run", "type": "string", "description": "Hash ID of the run during which this result was scraped", "example": "\"27d94c06df7e440d97def631c02261fa\""},
          {"path": "title", "type": "string", "description": "Headline or title of the news article", "example": "\"The Man Behind Eddie's She-Crab Soup\""},
          {"path": "url", "type": "string", "description": "Direct link to the full article", "example": "\"https://www.charlottemagazine.com/...\""},
          {"path": "source", "type": "string", "description": "Name of the news source or publisher", "example": "\"Charlotte Magazine\""},
          {"path": "short_description", "type": "string", "description": "Brief summary or excerpt of the article", "example": "\"Alberto Toussaint is the mastermind...\""},
          {"path": "image", "type": "string", "description": "URL of the article's featured image", "example": "\"https://wpcdn.us-midwest-1.vip.tn-cloud.net/...\""},
          {"path": "published_at", "type": "timestamp", "description": "Publication timestamp (ISO 8601)", "example": "\"2024-12-02T08:00:00Z\""},
          {"path": "scraping_time", "type": "timestamp", "description": "When this result was fetched", "example": "\"2025-07-04T03:59:31.056Z\""},
          {"path": "native_id", "type": "integer", "description": "Original identifier assigned by the source", "example": "818292"}
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "daf6d92ae704469196a14891d8f4b3fd"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional)",
        "example": "27d94c06df7e440d97def631c02261fa"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use the `published_at` field to sort articles by publication date."
      },
      {
        "type": "note",
        "content": "The `source` field identifies the news publisher for filtering or analysis."
      }
    ]
  },
  "seo": {
    "title": "Get Results - Google News Search Export - lobstr.io API",
    "description": "Retrieve scraped Google News articles including titles, sources, and publication dates."
  }
}
