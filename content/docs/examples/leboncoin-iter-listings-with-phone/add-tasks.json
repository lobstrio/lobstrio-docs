            "type": "string",
            "required": "Yes",
            "description": "Hash of your squid configured with the Leboncoin Listings & Phone Search Export crawler"
          },
          {
            "field": "**tasks**",
            "type": "array",
            "required": "Yes",
            "description": "Array of task objects, each containing a `url` field"
