{
  "slug": "examples/leboncoin-iter-listings-with-phone/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Leboncoin listings with phone numbers",
  "category": "Leboncoin Listings & Phone Search Export",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve scraped Leboncoin classified listings with extracted phone numbers. Results include all fields from the standard Leboncoin scraper plus phone data.",
    "sections": {
      "phoneFields": {
        "title": "Phone-Specific Fields",
        "content": "Phone extraction results:",
        "fields": [
          {
            "path": "phone",
            "type": "string | null",
            "description": "Extracted phone number",
            "example": "\"+33486259896\""
          },
          {
            "path": "has_phone",
            "type": "boolean",
            "description": "Whether a phone number was available",
            "example": "true"
          },
          {
            "path": "functions.phone.filling_date",
            "type": "string",
            "description": "When the phone was extracted",
            "example": "\"07/04/2025, 06:08:09 +0200\""
          }
        ]
      },
      "listingFields": {
        "title": "Listing Information",
        "content": "Core listing details:",
        "fields": [
          {
            "path": "id",
            "type": "integer",
            "description": "Unique result identifier",
            "example": "53557759"
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"result\"",
            "example": "\"result\""
          },
          {
            "path": "squid",
            "type": "string",
            "description": "Squid that produced this result",
            "example": "\"72d18e4c94534b829877bb7c092b1f80\""
          },
          {
            "path": "run",
            "type": "string",
            "description": "Run that produced this result",
            "example": "\"3ff48bb8ef19426e87fbb3e102dd4531\""
          },
          {
            "path": "title",
            "type": "string",
            "description": "Listing title/headline",
            "example": "\"Appartement 3 pièces\""
          },
          {
            "path": "description",
            "type": "string",
            "description": "Full listing description",
            "example": "\"Bel appartement...\""
          },
          {
            "path": "price",
            "type": "integer",
            "description": "Listing price",
            "example": "150000"
          },
          {
            "path": "url",
            "type": "string",
            "description": "Direct URL to the listing",
            "example": "\"https://www.leboncoin.fr/ad/...\""
          },
          {
            "path": "annonce_id",
            "type": "string",
            "description": "Leboncoin listing ID",
            "example": "\"3017342920\""
          }
        ]
      },
      "locationFields": {
        "title": "Location Information",
        "content": "Geographic details:",
        "fields": [
          {
            "path": "city",
            "type": "string",
            "description": "City name",
            "example": "\"Marseille\""
          },
          {
            "path": "postal_code",
            "type": "string",
            "description": "Postal code",
            "example": "\"13000\""
          },
          {
            "path": "department",
            "type": "string",
            "description": "French department",
            "example": "\"Bouches-du-Rhône\""
          },
          {
            "path": "region",
            "type": "string",
            "description": "Region name",
            "example": "\"Provence-Alpes-Côte d'Azur\""
          }
        ]
      },
      "sellerFields": {
        "title": "Seller Information",
        "content": "Details about the seller:",
        "fields": [
          {
            "path": "owner_name",
            "type": "string",
            "description": "Seller's display name",
            "example": "\"Jean Dupont\""
          },
          {
            "path": "owner_siren",
            "type": "string | null",
            "description": "Business SIREN number",
            "example": "\"123456789\""
          },
          {
            "path": "owner_store_id",
            "type": "string",
            "description": "Seller's store ID",
            "example": "\"1095173\""
          }
        ]
      },
      "propertyFields": {
        "title": "Real Estate Fields",
        "content": "Property-specific fields (when applicable):",
        "fields": [
          {
            "path": "area",
            "type": "string | null",
            "description": "Property area (sqm)",
            "example": "\"75\""
          },
          {
            "path": "room_count",
            "type": "integer | null",
            "description": "Number of rooms",
            "example": "3"
          },
          {
            "path": "DPE",
            "type": "string | null",
            "description": "Energy Performance rating (A-G)",
            "example": "\"C\""
          },
          {
            "path": "GES",
            "type": "string | null",
            "description": "Greenhouse Gas rating (A-G)",
            "example": "\"B\""
          },
          {
            "path": "furnished",
            "type": "boolean | null",
            "description": "Whether furnished",
            "example": "false"
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "72d18e4c94534b829877bb7c092b1f80"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional)",
        "example": "3ff48bb8ef19426e87fbb3e102dd4531"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Results per page (default: 50, max: 100)",
        "example": "50"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "The `phone` field is only populated when `functions.phone` is enabled and the seller has phone contact enabled."
      },
      {
        "type": "tip",
        "content": "Check `has_phone` before accessing the `phone` field to avoid null values."
      },
      {
        "type": "note",
        "content": "All other fields are identical to the Leboncoin Listings Search Export scraper."
      }
    ]
  },
  "seo": {
    "title": "Get Results - Leboncoin Listings & Phone Search Export - Lobstr.io API",
    "description": "Retrieve Leboncoin listings with phone numbers using the Lobstr.io API."
  }
}