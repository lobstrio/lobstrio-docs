{
  "slug": "examples/twitter-user-tweets-scraper/update-settings",
  "title": "Update Settings",
  "description": "Configure Twitter User Tweets Scraper settings",
  "category": "Examples",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/squids/{squid_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Configure your Twitter User Tweets Scraper squid settings. Control the number of tweets to fetch, time filtering, and whether to include retweets and pinned tweets.",
    "sections": {
      "scraperParams": {
        "title": "Scraper Parameters",
        "content": "Set these parameters in the `params` object:",
        "columns": [
          {
            "header": "Parameter",
            "key": "param"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Default",
            "key": "default"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "param": "**json**",
            "type": "boolean",
            "default": "false",
            "description": "If true, returns the complete raw JSON payload for each tweet"
          },
          {
            "param": "**max_results**",
            "type": "integer",
            "default": "null",
            "description": "Maximum number of tweets to scrape per user"
          },
          {
            "param": "**fetch_since**",
            "type": "string",
            "default": "null",
            "description": "Only collect items published after this point. Use a relative duration (24h, 7d, 2w) or an absolute date (YYYY-MM-DD)"
          },
          {
            "param": "**hours_back**",
            "type": "integer | null",
            "default": "null",
            "description": "Deprecated. Use `fetch_since` instead"
          },
          {
            "param": "**exclude_reposts**",
            "type": "boolean",
            "default": "false",
            "description": "If true, excludes retweets from results"
          },
          {
            "param": "**collect_pinned_tweets**",
            "type": "boolean",
            "default": "false",
            "description": "If true, includes pinned tweets in results"
          }
        ]
      },
      "squidSettings": {
        "title": "Squid Settings",
        "content": "Configure general squid settings:",
        "columns": [
          {
            "header": "Setting",
            "key": "setting"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "setting": "**name**",
            "type": "string",
            "description": "Display name for your squid configuration"
          },
          {
            "setting": "**concurrency**",
            "type": "integer",
            "description": "Number of parallel scraping threads (default: 1)"
          },
          {
            "setting": "**export_unique_results**",
            "type": "boolean",
            "description": "Export only unique results (deduplicated)"
          },
          {
            "setting": "**to_complete**",
            "type": "boolean",
            "description": "Run until all tasks complete"
          },
          {
            "setting": "**no_line_breaks**",
            "type": "boolean",
            "description": "Remove line breaks from results"
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `fetch_since` to monitor recent activity - set to `24` to only collect tweets from the last day."
      },
      {
        "type": "tip",
        "content": "Enable `exclude_reposts` to focus on original content only."
      },
      {
        "type": "note",
        "content": "Pinned tweets are not collected by default - enable `collect_pinned_tweets` if you need them."
      }
    ]
  },
