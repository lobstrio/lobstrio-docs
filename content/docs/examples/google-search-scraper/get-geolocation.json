{
  "slug": "examples/google-search-scraper/get-geolocation",
  "title": "Get Geolocation",
  "description": "Fetch valid location values for geographic search bias",
  "category": "Google Search Scraper",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/googlelocations",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Use this endpoint to fetch valid location values for the `params.location` setting in the Google Search Scraper. These values provide geographic bias for your search queries.",
    "sections": {
      "queryParams": {
        "title": "Query Parameters",
        "columns": [
          {"header": "Parameter", "key": "param"},
          {"header": "Required", "key": "required"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"param": "**q**", "required": "Yes", "description": "Substring to search for in region, district, or city names"},
          {"param": "**country_name**", "required": "Yes", "description": "Full country name to scope the search (e.g., `United States`)"}
        ]
      },
      "responseFields": {
        "title": "Response Fields",
        "columns": [
          {"header": "Field", "key": "field"},
          {"header": "Type", "key": "type"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"field": "**name**", "type": "string", "description": "Display name of the location (region, district, or city)"},
          {"field": "**canonical_name**", "type": "string", "description": "Full hierarchical name (e.g., `Alabama,United States`)"},
          {"field": "**country_name**", "type": "string", "description": "Country associated with this location"},
          {"field": "**country_code**", "type": "string", "description": "ISO 2-letter country code (e.g., `US`)"}
        ]
      }
    },
    "parameters": [
      {
        "name": "q",
        "type": "string",
        "required": true,
        "description": "Search substring for location names",
        "example": "Alabama"
      },
      {
        "name": "country_name",
        "type": "string",
        "required": true,
        "description": "Full country name",
        "example": "United States"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use the returned `name` value as your `params.location` setting."
      },
      {
        "type": "note",
        "content": "Location values provide geographic bias - search results will be relevant to that area."
      }
    ]
  },
  "seo": {
    "title": "Get Geolocation - Google Search Scraper - lobstr.io API",
    "description": "Fetch valid location values for geographic search bias in Google Search Scraper."
  }
}
