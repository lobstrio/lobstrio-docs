{
  "slug": "examples/google-maps-reviews-scraper/update-settings",
  "title": "Update Settings",
  "description": "Configure the Google Maps Reviews Scraper parameters",
  "category": "Examples",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/squids/{squid_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Configure the scraper parameters to control how reviews are collected. These settings determine sorting, filtering, and what data is extracted.",
    "sections": {
      "scraperParams": {
        "title": "Scraper Parameters",
        "content": "Set these parameters in the `params` object:",
        "columns": [
          {
            "header": "Parameter",
            "key": "param"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Default",
            "key": "default"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "param": "**sort_by**",
            "type": "string",
            "default": "newest",
            "description": "Sort reviews: `newest`, `most relevant`, or `highest rating`"
          },
          {
            "param": "**fetch_since**",
            "type": "string",
            "default": "null",
            "description": "Only collect items published after this point. Use a relative duration (24h, 7d, 2w) or an absolute date (YYYY-MM-DD)"
          },
          {
            "param": "**hours_back**",
            "type": "integer",
            "default": "null",
            "description": "Deprecated. Use `fetch_since` instead"
          },
          {
            "param": "**max_results**",
            "type": "integer",
            "default": "20",
            "description": "Maximum number of reviews to collect per place"
          },
          {
            "param": "**language**",
            "type": "string",
            "default": "English (United States)",
            "description": "Language for extracted reviews"
          },
          {
            "param": "**functions.short_link**",
            "type": "boolean",
            "default": "false",
            "description": "Collect shortened review links (additional costs may apply)"
          }
        ]
      },
      "squidSettings": {
        "title": "Squid Settings",
        "content": "You can also configure general squid settings:",
        "columns": [
          {
            "header": "Setting",
            "key": "setting"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "setting": "**name**",
            "type": "string",
            "description": "Name for your squid configuration"
          },
          {
            "setting": "**concurrency**",
            "type": "integer",
            "description": "Number of parallel scraping workers (1-10)"
          },
          {
            "setting": "**export_unique_results**",
            "type": "boolean",
            "description": "Only export unique results (deduplicated)"
          },
          {
            "setting": "**run_notify**",
            "type": "string",
            "description": "When to send notifications: `on_success`, `on_failure`, `always`, `never`"
          },
          {
            "setting": "**timezone**",
            "type": "string",
            "description": "Timezone for timestamps (e.g., `Europe/Paris`)"
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `sort_by: newest` to monitor recent reviews for reputation management."
      },
      {
        "type": "tip",
        "content": "Set `fetch_since` to limit results to recent reviews only, reducing processing time and costs."
      },
      {
        "type": "warning",
        "content": "Enabling `functions.short_link` may incur additional costs. Only enable if you need shortened URLs."
      },
      {
        "type": "note",
        "content": "Changes take effect on the next run. Running jobs use the settings from when they started."
      }
    ]
  },
  "seo": {
    "title": "Update Settings - Google Maps Reviews Scraper - lobstr.io API",
    "description": "Configure the Google Maps Reviews Scraper parameters including sort order, language, and result limits."
  },
  "subcategory": "Google Maps Reviews Scraper"
}
