{
  "slug": "examples/instagram-posts-scraper/update-settings",
  "title": "Update Settings",
  "description": "Configure the Instagram Posts Scraper settings",
  "category": "Examples",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/squids/{squid_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Configure your Instagram Posts Scraper squid settings. Control the maximum number of posts collected, filter by time range, and exclude pinned posts.",
    "sections": {
      "scraperParams": {
        "title": "Scraper Parameters",
        "content": "Set these parameters in the `params` object:",
        "columns": [
          {
            "header": "Parameter",
            "key": "param"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Default",
            "key": "default"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "param": "**max_results**",
            "type": "integer",
            "default": "unlimited",
            "description": "Total posts the crawler will collect per profile"
          },
          {
            "param": "**max_unique_results_per_run**",
            "type": "integer",
            "default": "unlimited",
            "description": "Maximum number of unique posts retrieved across all tasks in the entire run"
          },
          {
            "param": "**fetch_since**",
            "type": "string",
            "default": "unlimited",
            "description": "Only collect items published after this point. Use a relative duration (24h, 7d, 2w) or an absolute date (YYYY-MM-DD)"
          },
          {
            "param": "**hours_back**",
            "type": "integer",
            "default": "unlimited",
            "description": "Deprecated. Use `fetch_since` instead"
          },
          {
            "param": "**skip_pinned_posts**",
            "type": "boolean",
            "default": "false",
            "description": "If enabled, pinned posts will be excluded from the results"
          }
        ]
      },
      "squidSettings": {
        "title": "Squid Settings",
        "content": "Configure general squid settings:",
        "columns": [
          {
            "header": "Setting",
            "key": "setting"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "setting": "**name**",
            "type": "string",
            "description": "Display name for your squid configuration"
          },
          {
            "setting": "**concurrency**",
            "type": "integer",
            "description": "Number of parallel scraping threads (default: 1)"
          },
          {
            "setting": "**export_unique_results**",
            "type": "boolean",
            "description": "Export only unique results (deduplicated)"
          },
          {
            "setting": "**to_complete**",
            "type": "boolean",
            "description": "Run until all tasks complete"
          },
          {
            "setting": "**no_line_breaks**",
            "type": "boolean",
            "description": "Remove line breaks from results"
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
