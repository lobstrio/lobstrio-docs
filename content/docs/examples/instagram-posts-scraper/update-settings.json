        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `fetch_since` to only collect recent posts - great for monitoring accounts for new content."
      },
      {
        "type": "note",
        "content": "Leave limits empty or null for unlimited collection."
      },
      {
        "type": "tip",
        "content": "Enable `skip_pinned_posts` when you only want organic timeline posts without promotional pinned content."
      }
    ]
  },
