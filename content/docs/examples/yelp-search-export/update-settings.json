{
  "slug": "examples/yelp-search-export/update-settings",
  "title": "Update Settings",
  "description": "Configure Yelp Search Export scraper settings",
  "category": "Examples",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/squids/{squid_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Configure your Yelp Search Export squid settings. Control result limits and enable contact harvesting to extract email addresses from business websites.",
    "sections": {
      "scraperParams": {
        "title": "Scraper Parameters",
        "content": "Set these parameters in the `params` object:",
        "columns": [
          {
            "header": "Parameter",
            "key": "param"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Default",
            "key": "default"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "param": "**max_results**",
            "type": "integer",
            "default": "null",
            "description": "Maximum number of businesses to collect before stopping"
          },
          {
            "param": "**collect_contacts**",
            "type": "boolean",
            "default": "false",
            "description": "Visit each business's website to extract email addresses and social links"
          }
        ]
      },
      "squidSettings": {
        "title": "Squid Settings",
        "content": "Configure general squid settings:",
        "columns": [
          {
            "header": "Setting",
            "key": "setting"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "setting": "**name**",
            "type": "string",
            "description": "Display name for your squid configuration"
          },
          {
            "setting": "**concurrency**",
            "type": "integer",
            "description": "Number of parallel scraping threads (default: 1)"
          },
          {
            "setting": "**export_unique_results**",
            "type": "boolean",
            "description": "Export only unique results (deduplicated)"
          },
          {
            "setting": "**to_complete**",
            "type": "boolean",
            "description": "Run until all tasks complete"
          },
          {
            "setting": "**no_line_breaks**",
            "type": "boolean",
            "description": "Remove line breaks from results"
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Enable `collect_contacts` to extract email addresses from business websites for outreach campaigns."
      },
      {
        "type": "warning",
        "content": "Enabling `collect_contacts` adds extra HTTP requests per business, increasing total run time and credit usage."
      },
      {
        "type": "note",
        "content": "Use `max_results` to limit the scope of large searches and control costs."
      }
    ]
  },
  "seo": {
    "title": "Update Settings - Yelp Search Export - lobstr.io API",
    "description": "Configure Yelp Search Export scraper settings using the lobstr.io API."
  },
  "subcategory": "Yelp Search Export"
}
