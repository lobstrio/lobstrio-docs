{
  "slug": "examples/vinted-products-scraper/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Vinted product listings with pricing and seller information",
  "category": "Vinted Products Scraper",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve scraped product listings from Vinted including product details, pricing breakdown, and seller information.",
    "sections": {
      "productFields": {
        "title": "Product Information",
        "content": "Basic product details:",
        "fields": [
          {"path": "id", "type": "integer", "description": "Unique result identifier", "example": "2220866"},
          {"path": "object", "type": "string", "description": "Always \"result\"", "example": "\"result\""},
          {"path": "squid", "type": "string", "description": "Squid that produced this result", "example": "\"2eea95bc41594fb5898e86e671e4bb3f\""},
          {"path": "run", "type": "string", "description": "Run that produced this result", "example": "\"c52de994a19544de9c729b2e4b428255\""},
          {"path": "title", "type": "string", "description": "Product title/headline", "example": "\"Nike Air Max 90 - Size 42\""},
          {"path": "description", "type": "string | null", "description": "Product description if provided", "example": "\"Great condition, worn only a few times\""},
          {"path": "brand_title", "type": "string | null", "description": "Brand name of the item", "example": "\"Nike\""},
          {"path": "size_title", "type": "string | null", "description": "Size label", "example": "\"S / 36 / 8\""},
          {"path": "badge", "type": "string | null", "description": "Special badge (e.g., \"New\", \"Sale\")", "example": "null"},
          {"path": "status", "type": "string | null", "description": "Listing status (e.g., \"sold\", \"reserved\")", "example": "null"},
          {"path": "url", "type": "string", "description": "Direct URL to the Vinted listing", "example": "\"https://www.vinted.fr/items/5729689121-...\""},
          {"path": "image_url", "type": "string | null", "description": "URL of the product image", "example": "\"https://images.vinted.net/...\""},
          {"path": "internal_id", "type": "string", "description": "Vinted's internal listing identifier", "example": "\"5729689121\""}
        ]
      },
      "pricingFields": {
        "title": "Pricing Information",
        "content": "Price breakdown for each listing:",
        "fields": [
          {"path": "price", "type": "number", "description": "Listing price in specified currency", "example": "45"},
          {"path": "service_fee", "type": "number", "description": "Platform service fee", "example": "4.5"},
          {"path": "total_item_price", "type": "number", "description": "Sum of price + service_fee", "example": "49.5"},
          {"path": "currency", "type": "string | null", "description": "Currency code", "example": "\"EUR\""},
          {"path": "discount", "type": "number | null", "description": "Discount percentage if applicable", "example": "null"}
        ]
      },
      "engagementFields": {
        "title": "Engagement Metrics",
        "content": "User interaction data:",
        "fields": [
          {"path": "favourite_count", "type": "integer", "description": "Number of users who favorited this item", "example": "12"},
          {"path": "view_count", "type": "integer", "description": "Number of times listing was viewed", "example": "89"},
          {"path": "is_favourite", "type": "boolean", "description": "Whether current user favorited this item", "example": "false"},
          {"path": "promoted", "type": "boolean", "description": "Whether listing is promoted (paid placement)", "example": "false"},
          {"path": "is_visible", "type": "boolean", "description": "Whether listing is publicly visible", "example": "true"},
          {"path": "is_for_swap", "type": "boolean | null", "description": "Whether item is available for swap", "example": "false"}
        ]
      },
      "sellerFields": {
        "title": "Seller Information",
        "content": "Details about the seller:",
        "fields": [
          {"path": "user_id", "type": "string", "description": "Unique identifier of the seller", "example": "\"209950955\""},
          {"path": "user_login", "type": "string", "description": "Seller's Vinted username", "example": "\"sneaker_collector\""},
          {"path": "user_profile_url", "type": "string", "description": "URL to seller's profile page", "example": "\"https://www.vinted.fr/member/209950955-...\""},
          {"path": "user_photo_url", "type": "string | null", "description": "URL of seller's profile photo", "example": "\"https://images.vinted.net/...\""},
          {"path": "user_business", "type": "boolean", "description": "Whether seller is a registered business", "example": "false"},
          {"path": "user_is_hidden", "type": "boolean | null", "description": "Whether seller's identity is hidden", "example": "null"},
          {"path": "user_is_sus", "type": "boolean | null", "description": "Whether seller is flagged as suspicious", "example": "null"}
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "2eea95bc41594fb5898e86e671e4bb3f"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional, filters to that run only)",
        "example": "c52de994a19544de9c729b2e4b428255"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Results per page (default: 50, max: 100)",
        "example": "50"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use the `next` URL in the response to paginate through all results."
      },
      {
        "type": "tip",
        "content": "Check `user_business` to identify professional sellers vs. private individuals."
      },
      {
        "type": "note",
        "content": "The `total_item_price` includes the platform service fee that buyers pay."
      }
    ]
  },
  "seo": {
    "title": "Get Results - Vinted Products Scraper - Lobstr.io API",
    "description": "Retrieve Vinted product listings with pricing and seller data using the Lobstr.io API."
  }
}
