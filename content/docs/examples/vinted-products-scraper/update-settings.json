        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Set `max_pages` to limit scraping depth and control costs for large catalog searches."
      },
      {
        "type": "note",
        "content": "Vinted catalog pages typically contain 24-48 products per page."
      }
    ]
  },
