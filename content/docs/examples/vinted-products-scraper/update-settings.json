  "metadata": {
    "method": "POST",
    "endpoint": "/v1/squids/{squid_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Configure your squid settings for the Vinted Products Scraper. Control pagination depth to limit the number of catalog pages scraped.",
    "sections": {
      "scraperParams": {
        "title": "Scraper Parameters",
        "content": "Set these parameters in the `params` object:",
        "columns": [
          {"header": "Parameter", "key": "param"},
          {"header": "Type", "key": "type"},
          {"header": "Default", "key": "default"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"param": "**max_pages**", "type": "integer", "default": "null", "description": "Maximum number of catalog pages to scrape per task"}
        ]
      },
      "squidSettings": {
        "title": "Squid Settings",
        "content": "Configure general squid settings:",
        "columns": [
          {"header": "Setting", "key": "setting"},
          {"header": "Type", "key": "type"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"setting": "**name**", "type": "string", "description": "Display name for your squid configuration"},
          {"setting": "**concurrency**", "type": "integer", "description": "Number of parallel scraping workers (default: 1)"},
          {"setting": "**export_unique_results**", "type": "boolean", "description": "Export only unique results (deduplicated)"},
          {"setting": "**to_complete**", "type": "boolean", "description": "Run until all tasks complete"},
          {"setting": "**no_line_breaks**", "type": "boolean", "description": "Remove line breaks from results"}
        ]
      }
    },
    "parameters": [],
