{
  "slug": "examples/leboncoin-auto-message-sender/update-settings",
  "title": "Update Settings",
  "description": "Configure Leboncoin Auto Message Sender settings and message template",
  "category": "Examples",
  "metadata": {
    "method": "POST",
    "endpoint": "/v1/squids/{squid_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Configure your Leboncoin Auto Message Sender settings including the message template with dynamic variables that are replaced with listing-specific values.",
    "sections": {
      "messageParams": {
        "title": "Message Parameters",
        "content": "Configure the message content and targeting:",
        "columns": [
          {
            "header": "Parameter",
            "key": "param"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Default",
            "key": "default"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "param": "**message**",
            "type": "string",
            "default": "—",
            "description": "Template for the message sent to sellers. Supports dynamic variables (see below)"
          },
          {
            "param": "**fetch_since**",
            "type": "string",
            "default": "null",
            "description": "Only collect items published after this point. Use a relative duration (24h, 7d, 2w) or an absolute date (YYYY-MM-DD)"
          },
          {
            "param": "**hours_back**",
            "type": "integer | null",
            "default": "null",
            "description": "Deprecated. Use `fetch_since` instead"
          },
          {
            "param": "**max_results**",
            "type": "integer | null",
            "default": "null",
            "description": "Maximum number of listings to process before stopping"
          },
          {
            "param": "**max_unique_results_per_run**",
            "type": "integer | null",
            "default": "null",
            "description": "Maximum unique results across all tasks in a single run"
          }
        ]
      },
      "templateVariables": {
        "title": "Message Template Variables",
        "content": "The message parameter supports dynamic variables that are replaced with listing-specific values:",
        "columns": [
          {
            "header": "Variable",
            "key": "variable"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "variable": "**#title#**",
            "description": "The listing title (e.g., \"Appartement 3 pièces 88 m²\")"
          },
          {
            "variable": "**#pseudo#**",
            "description": "The seller's display name/pseudonym"
          }
        ]
      },
      "squidSettings": {
        "title": "Squid Settings",
        "content": "Configure general squid settings:",
        "columns": [
          {
            "header": "Setting",
            "key": "setting"
          },
          {
            "header": "Type",
            "key": "type"
          },
          {
            "header": "Description",
            "key": "description"
          }
        ],
        "rows": [
          {
            "setting": "**name**",
            "type": "string",
            "description": "Display name for your squid configuration"
          },
          {
            "setting": "**concurrency**",
            "type": "integer",
            "description": "Number of parallel message sending threads (default: 1)"
          },
          {
            "setting": "**export_unique_results**",
            "type": "boolean",
            "description": "Export only unique results (deduplicated)"
          },
          {
            "setting": "**to_complete**",
            "type": "boolean",
            "description": "Run until all tasks complete"
          },
          {
            "setting": "**no_line_breaks**",
            "type": "boolean",
            "description": "Remove line breaks from results"
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      },
      {
        "key": "Content-Type",
        "value": "application/json",
        "required": true,
        "description": "Request body format"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Example message template: \"Hello #pseudo#,\\n\\nI am interested in your listing: #title#.\\n\\nPlease contact me via Leboncoin messaging.\\n\\nThank you!\""
      },
      {
        "type": "warning",
        "content": "Keep concurrency low (1-2) to avoid rate limiting from Leboncoin."
      },
      {
        "type": "note",
        "content": "The same message will not be sent twice to the same listing (duplicate detection via message_hash)."
      }
    ]
  },
  "seo": {
    "title": "Update Settings - Leboncoin Auto Message Sender - lobstr.io API",
    "description": "Configure Leboncoin auto message settings and templates using the lobstr.io API."
  },
  "subcategory": "Leboncoin Auto Message Sender"
}
