{
  "slug": "examples/facebook-pages-search-export/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Facebook Pages data",
  "category": "Facebook Pages Search Export",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve scraped Facebook Pages data including page names, categories, contact information, and social metrics.",
    "sections": {
      "coreFields": {
        "title": "Core Result Fields",
        "content": "Standard result identifiers:",
        "fields": [
          {"path": "id", "type": "integer", "description": "Unique result identifier", "example": "53557759"},
          {"path": "object", "type": "string", "description": "Always \"result\"", "example": "\"result\""},
          {"path": "squid", "type": "string", "description": "Squid that produced this result", "example": "\"72d18e4c94534b829877bb7c092b1f80\""},
          {"path": "run", "type": "string", "description": "Run that produced this result", "example": "\"3ff48bb8ef19426e87fbb3e102dd4531\""}
        ]
      },
      "pageFields": {
        "title": "Page Information",
        "content": "Basic page details:",
        "fields": [
          {"path": "name", "type": "string", "description": "Name of the Facebook page", "example": "\"Coffee House Downtown\""},
          {"path": "url", "type": "string", "description": "Full URL to the Facebook page", "example": "\"https://www.facebook.com/coffeehousedowntown\""},
          {"path": "slug", "type": "string", "description": "URL-friendly slug for the page", "example": "\"coffeehousedowntown\""},
          {"path": "category", "type": "string", "description": "Category of the page", "example": "\"Coffee Shop\""}
        ]
      },
      "metricsFields": {
        "title": "Social Metrics",
        "content": "Engagement counts:",
        "fields": [
          {"path": "likes", "type": "integer", "description": "Number of likes the page has received", "example": "15000"},
          {"path": "followers", "type": "integer", "description": "Number of followers the page has", "example": "14500"}
        ]
      },
      "contactFields": {
        "title": "Contact Information",
        "content": "Contact details from the page:",
        "fields": [
          {"path": "phone", "type": "string | null", "description": "Contact phone number", "example": "\"+1-555-123-4567\""},
          {"path": "email", "type": "string | null", "description": "Contact email", "example": "\"info@coffeehouse.com\""},
          {"path": "website", "type": "string | null", "description": "Website URL from About section", "example": "\"https://coffeehouse.com\""},
          {"path": "address", "type": "string | null", "description": "Physical address", "example": "\"123 Main St, New York, NY 10001\""},
          {"path": "map_url", "type": "string | null", "description": "URL to location on maps", "example": "\"https://maps.google.com/...\""}
        ]
      },
      "socialFields": {
        "title": "Social Links",
        "content": "Associated social media profiles:",
        "fields": [
          {"path": "instagram", "type": "string | null", "description": "Instagram profile URL", "example": "\"https://instagram.com/coffeehouse\""}
        ]
      },
      "timestampFields": {
        "title": "Timestamps",
        "fields": [
          {"path": "scraping_time", "type": "string", "description": "When this result was scraped (ISO 8601)", "example": "\"2025-07-04T04:08:09.340Z\""}
        ]
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "Hash of the squid to get results from",
        "example": "72d18e4c94534b829877bb7c092b1f80"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Hash of a specific run (optional)",
        "example": "3ff48bb8ef19426e87fbb3e102dd4531"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number (default: 1)",
        "example": "1"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Results per page (default: 50, max: 100)",
        "example": "50"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use the `phone` and `email` fields to build contact lists for outreach campaigns."
      },
      {
        "type": "tip",
        "content": "Filter by `category` to segment results by business type."
      },
      {
        "type": "note",
        "content": "Contact fields may be null if not provided on the Facebook page."
      }
    ]
  },
  "seo": {
    "title": "Get Results - Facebook Pages Search Export - lobstr.io API",
    "description": "Retrieve Facebook Pages data using the lobstr.io API."
  }
}
