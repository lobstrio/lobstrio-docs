{
  "slug": "examples/pages-jaunes-iter-companies/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Pages Jaunes business listings with company details and registration numbers",
  "category": "Examples",
  "subcategory": "Pages Jaunes Companies Search Export",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/results",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve business listings scraped from Pages Jaunes search results. Each result contains comprehensive company information including contact details, addresses, official French business registration numbers (SIRET/SIREN), NAF activity codes, and social media profiles.",
    "sections": {
      "resultFields": {
        "title": "Result Fields",
        "content": "Each result object contains the following business listing data:",
        "fields": [
          {
            "path": "id",
            "type": "integer",
            "description": "Unique identifier for this result record",
            "example": "2454"
          },
          {
            "path": "object",
            "type": "string",
            "description": "Object type, always \"result\"",
            "example": "\"result\""
          },
          {
            "path": "squid",
            "type": "string",
            "description": "Hash ID of the squid that produced this result",
            "example": "\"4a68464aef0a4067b161f64579278a58\""
          },
          {
            "path": "run",
            "type": "string",
            "description": "Hash ID of the run during which this result was scraped",
            "example": "\"e13f5d4f74af4f4f89c5a4fc535a031e\""
          },
          {
            "path": "title",
            "type": "string",
            "description": "Business name or listing title",
            "example": "\"Boulanger Opera\""
          },
          {
            "path": "activity",
            "type": "string",
            "description": "Search filter/category used",
            "example": "\"magasins d'electromenager +2\""
          },
          {
            "path": "description",
            "type": "string",
            "description": "Business description text",
            "example": "\"Bonjour et bienvenue dans votre magasin Boulanger...\""
          },
          {
            "path": "full_address",
            "type": "string",
            "description": "Complete street address",
            "example": "\"30 boulevard Capucines 75009 Paris\""
          },
          {
            "path": "city",
            "type": "string",
            "description": "City where the business is located",
            "example": "\"Paris\""
          },
          {
            "path": "zip_code",
            "type": "string",
            "description": "Postal code for the listing",
            "example": "\"75009\""
          },
          {
            "path": "phone",
            "type": "string",
            "description": "Primary phone number",
            "example": "\"01 42 65 12 34\""
          },
          {
            "path": "additional_phone",
            "type": "string",
            "description": "Secondary phone number if available",
            "example": "\"\""
          },
          {
            "path": "email",
            "type": "string",
            "description": "Contact email address (if collect_contacts enabled)",
            "example": "\"contact@example.com\""
          },
          {
            "path": "website",
            "type": "string",
            "description": "Business website URL",
            "example": "\"https://www.boulanger.com/magasins/...\""
          },
          {
            "path": "siret",
            "type": "string",
            "description": "14-digit French business identification number",
            "example": "\"34738457001969\""
          },
          {
            "path": "siren",
            "type": "string",
            "description": "9-digit company registration number",
            "example": "\"347384570\""
          },
          {
            "path": "naf_code",
            "type": "string",
            "description": "NAF activity classification code",
            "example": "\"4754Z\""
          },
          {
            "path": "company_size",
            "type": "string",
            "description": "Company employee count category",
            "example": "\"5000 a 9999 salaries\""
          },
          {
            "path": "company_creation_date",
            "type": "string",
            "description": "ISO date when company was founded",
            "example": "\"1988-03-24T00:00:00Z\""
          },
          {
            "path": "company_hq",
            "type": "string",
            "description": "Address of company headquarters",
            "example": "\"\""
          },
          {
            "path": "shop_size",
            "type": "string",
            "description": "Establishment employee count category",
            "example": "\"50 a 99 salaries\""
          },
          {
            "path": "shop_type",
            "type": "string",
            "description": "Establishment type",
            "example": "\"Etablissement secondaire\""
          },
          {
            "path": "facebook",
            "type": "string|null",
            "description": "Facebook page URL if listed",
            "example": "null"
          },
          {
            "path": "instagram",
            "type": "string|null",
            "description": "Instagram profile URL if listed",
            "example": "\"https://www.instagram.com/Boulangeropera/\""
          },
          {
            "path": "image_url",
            "type": "string",
            "description": "URL of business logo or main image",
            "example": "\"/media/newdam/preset-thumbnail-logo-desktop/...\""
          },
          {
            "path": "tags",
            "type": "string",
            "description": "Comma-separated service tags",
            "example": "\"livraison a domicile, retrait en magasin, ...\""
          },
          {
            "path": "score",
            "type": "number",
            "description": "Average rating score",
            "example": "1"
          },
          {
            "path": "ratings",
            "type": "integer",
            "description": "Number of customer ratings",
            "example": "0"
          },
          {
            "path": "item_id",
            "type": "string",
            "description": "Internal listing identifier",
            "example": "\"0001562094139200\""
          },
          {
            "path": "url",
            "type": "string",
            "description": "Direct URL to the listing on Pages Jaunes",
            "example": "\"https://www.pagesjaunes.fr/pros/detail?code_etablissement=...\""
          },
          {
            "path": "scraping_time",
            "type": "string",
            "description": "ISO timestamp when the listing was fetched",
            "example": "\"2025-07-28T08:58:20.896Z\""
          },
          {
            "path": "functions",
            "type": "object|null",
            "description": "Function execution metadata including filling_date",
            "example": "{\"results_details\": {\"filling_date\": \"07/28/2025, 10:58:20 +0200\"}}"
          }
        ]
      },
      "businessRegistration": {
        "title": "French Business Registration Numbers",
        "content": "The scraper collects official French business identifiers when `functions.results_details` is enabled:",
        "list": [
          "**SIRET** (14 digits): Unique identifier for each business establishment",
          "**SIREN** (9 digits): Company-level registration number (first 9 digits of SIRET)",
          "**NAF Code**: French activity classification (equivalent to NACE codes)"
        ]
      },
      "pagination": {
        "title": "Pagination",
        "content": "Results are paginated. Use the `next` and `previous` URLs in the response to navigate through pages, or use `page` and `page_size` query parameters."
      }
    },
    "parameters": [
      {
        "name": "squid",
        "type": "string",
        "required": true,
        "description": "The squid hash ID to get results from"
      },
      {
        "name": "run",
        "type": "string",
        "required": false,
        "description": "Filter results by specific run hash ID"
      },
      {
        "name": "page",
        "type": "integer",
        "required": false,
        "description": "Page number for pagination (default: 1)"
      },
      {
        "name": "page_size",
        "type": "integer",
        "required": false,
        "description": "Number of results per page (default: 100, max: 1000)"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use SIRET numbers to verify business legitimacy through the French government's official SIRENE database (sirene.fr)."
      },
      {
        "type": "note",
        "content": "NAF codes follow the French statistical classification system. Code 4754Z, for example, represents retail sale of electrical household appliances."
      }
    ]
  },
  "examples": {
    "curl": "examples/pages-jaunes-companies-search-export/get-results",
    "python": "examples/pages-jaunes-companies-search-export/get-results",
    "response": "examples/pages-jaunes-companies-search-export/get-results"
  },
  "seo": {
    "title": "Get Results - Pages Jaunes Companies Search Export - lobstr.io API",
    "description": "Retrieve scraped Pages Jaunes business listings including SIRET, SIREN, NAF codes, contact details, and social media profiles from France's Yellow Pages."
  }
}