{
  "slug": "examples/instagram-profile-scraper/get-results",
  "title": "Get Results",
  "description": "Retrieve scraped Instagram profile data from your squid",
  "category": "Instagram Profile Scraper",
  "metadata": {
    "method": "GET",
    "endpoint": "/v2/squid/{squid_id}/result",
    "requiresAuth": true
  },
  "content": {
    "introduction": "Retrieve Instagram profile data from your completed scraping tasks. The scraper extracts comprehensive profile information including bio, stats, business details, and latest posts.\n\n{{RENDER:profileFields}}\n\n{{RENDER:statsFields}}\n\n{{RENDER:accountTypeFields}}\n\n{{RENDER:businessFields}}\n\n{{RENDER:externalUrlFields}}\n\n{{RENDER:contentFields}}\n\n{{RENDER:latestPostFields}}",
    "sections": {
      "profileFields": {
        "title": "Profile Information",
        "fields": [
          { "path": "profile_url", "type": "string", "description": "Full Instagram profile URL", "example": "\"https://www.instagram.com/leomessi/\"" },
          { "path": "username", "type": "string", "description": "Instagram username", "example": "\"leomessi\"" },
          { "path": "full_name", "type": "string", "description": "Display name", "example": "\"Leo Messi\"" },
          { "path": "biography", "type": "string", "description": "Profile bio text", "example": "\"Welcome to my official Instagram account\"" },
          { "path": "profile_pic_url", "type": "string", "description": "Profile picture URL", "example": "\"https://scontent.cdninstagram.com/...\"" },
          { "path": "profile_id", "type": "bigint", "description": "Instagram user ID", "example": "427553890" },
          { "path": "fbid", "type": "bigint", "description": "Facebook ID (linked account)", "example": "123456789" }
        ]
      },
      "statsFields": {
        "title": "Profile Statistics",
        "fields": [
          { "path": "followers_count", "type": "integer", "description": "Number of followers", "example": "500000000" },
          { "path": "follows_count", "type": "integer", "description": "Number of accounts followed", "example": "500" },
          { "path": "posts_count", "type": "integer", "description": "Total number of posts", "example": "1000" },
          { "path": "highlight_reel_count", "type": "integer", "description": "Number of story highlights", "example": "5" },
          { "path": "igtv_video_count", "type": "integer", "description": "Number of IGTV videos", "example": "12" }
        ]
      },
      "accountTypeFields": {
        "title": "Account Type Flags",
        "fields": [
          { "path": "is_private", "type": "boolean", "description": "Whether profile is private", "example": "false" },
          { "path": "is_verified", "type": "boolean", "description": "Whether profile has blue checkmark", "example": "true" },
          { "path": "is_business_account", "type": "boolean", "description": "Whether it's a business account", "example": "true" },
          { "path": "is_professional_account", "type": "boolean", "description": "Whether it's a professional account", "example": "true" },
          { "path": "joined_recently", "type": "boolean", "description": "Whether account was created recently", "example": "false" },
          { "path": "has_clips", "type": "boolean", "description": "Whether profile has Reels", "example": "true" },
          { "path": "has_guides", "type": "boolean", "description": "Whether profile has Guides", "example": "false" },
          { "path": "has_channel", "type": "boolean", "description": "Whether profile has a broadcast channel", "example": "false" }
        ]
      },
      "businessFields": {
        "title": "Business Information",
        "content": "These fields are populated for business/professional accounts.",
        "fields": [
          { "path": "category", "type": "string", "description": "Business category", "example": "\"Athlete\"" },
          { "path": "business_email", "type": "string", "description": "Public business email", "example": "\"contact@example.com\"" },
          { "path": "business_phone_number", "type": "string", "description": "Public business phone", "example": "\"+1234567890\"" },
          { "path": "business_contact_method", "type": "string", "description": "Preferred contact method", "example": "\"CALL\"" }
        ]
      },
      "externalUrlFields": {
        "title": "External Links",
        "fields": [
          { "path": "external_url_1", "type": "object", "description": "First external link", "example": "{\"url\": \"https://example.com\", \"link_type\": \"external\"}" },
          { "path": "external_url_2", "type": "object", "description": "Second external link", "example": "{\"url\": \"https://shop.example.com\", \"link_type\": \"external\"}" },
          { "path": "all_external_urls", "type": "array", "description": "Array of all external URLs", "example": "[{\"url\": \"...\", \"link_type\": \"external\"}]" }
        ]
      },
      "contentFields": {
        "title": "Content Availability",
        "fields": [
          { "path": "latest_igtv_video_1", "type": "object", "description": "First IGTV video with id, shortcode, url, title, caption, duration, views, likes, comments", "example": "{\"id\": \"123\", \"title\": \"My Video\", ...}" },
          { "path": "latest_igtv_video_2", "type": "object", "description": "Second IGTV video", "example": "{}" },
          { "path": "latest_igtv_video_3", "type": "object", "description": "Third IGTV video", "example": "{}" },
          { "path": "latest_igtv_video_4", "type": "object", "description": "Fourth IGTV video", "example": "{}" }
        ]
      },
      "latestPostFields": {
        "title": "Latest Posts",
        "content": "Up to 12 latest posts are extracted, each containing:",
        "fields": [
          { "path": "latest_post_1.id", "type": "string", "description": "Post ID", "example": "\"987654321\"" },
          { "path": "latest_post_1.shortcode", "type": "string", "description": "Post shortcode for URL", "example": "\"XYZ789\"" },
          { "path": "latest_post_1.url", "type": "string", "description": "Post URL", "example": "\"https://www.instagram.com/p/XYZ789/\"" },
          { "path": "latest_post_1.type", "type": "string", "description": "Content type (GraphImage, GraphVideo, GraphSidecar)", "example": "\"GraphImage\"" },
          { "path": "latest_post_1.caption", "type": "string", "description": "Post caption", "example": "\"Great day!\"" },
          { "path": "latest_post_1.likes", "type": "integer", "description": "Number of likes", "example": "15000" },
          { "path": "latest_post_1.comments", "type": "integer", "description": "Number of comments", "example": "500" },
          { "path": "latest_post_1.posted_at", "type": "integer", "description": "Unix timestamp of post", "example": "1640100000" },
          { "path": "latest_post_1.display_url", "type": "string", "description": "Image/thumbnail URL", "example": "\"https://...\"" },
          { "path": "latest_post_1.location", "type": "string", "description": "Tagged location", "example": "\"Miami\"" },
          { "path": "latest_post_1.tagged_users", "type": "array", "description": "Users tagged in post", "example": "[{\"username\": \"friend1\"}]" }
        ]
      }
    },
    "parameters": [
      {
        "name": "limit",
        "type": "integer",
        "required": false,
        "description": "Number of results per page (default: 10, max: 100)",
        "example": "10"
      },
      {
        "name": "offset",
        "type": "integer",
        "required": false,
        "description": "Number of results to skip for pagination",
        "example": "0"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use `is_business_account` to filter for business profiles that have public contact information."
      },
      {
        "type": "note",
        "content": "Private accounts (`is_private: true`) return limited data - only basic profile info is available."
      },
      {
        "type": "tip",
        "content": "Check `business_email` and `business_phone_number` for lead generation from professional accounts."
      }
    ]
  },
  "seo": {
    "title": "Get Results - Instagram Profile Scraper - lobstr.io API",
    "description": "Learn how to retrieve scraped Instagram profile data including bio, stats, business info, and latest posts using the lobstr.io API."
  }
}
