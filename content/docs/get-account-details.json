{
  "slug": "get-account-details",
  "title": "Get Account Details",
  "description": "Retrieve detailed information about a specific platform account",
  "category": "Account",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/accounts/{account_hash}",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint retrieves detailed information about a specific platform account using its hash ID.",
    "sections": {
      "responseFields": {
        "title": "Response Field Explanations",
        "fields": [
          {
            "path": "id",
            "type": "string",
            "description": "Unique account identifier",
            "example": "\"d3e97f2cd33658f301bdbe807402ab30\""
          },
          {
            "path": "object",
            "type": "string",
            "description": "Always \"account\"",
            "example": "\"account\""
          },
          {
            "path": "username",
            "type": "string",
            "description": "Platform username",
            "example": "\"hashamxcom\""
          },
          {
            "path": "created_at",
            "type": "string",
            "description": "Account creation timestamp (ISO 8601)",
            "example": "\"2024-03-08T15:15:53Z\""
          },
          {
            "path": "last_synchronization_time",
            "type": "string",
            "description": "Last successful sync timestamp",
            "example": "\"2024-12-16T10:28:43Z\""
          },
          {
            "path": "status",
            "type": "string",
            "description": "HTTP status code indicating account health",
            "example": "\"200\""
          },
          {
            "path": "status_code_info",
            "type": "string",
            "description": "Status information keyword",
            "example": "\"synchronized\""
          },
          {
            "path": "status_code_description",
            "type": "string",
            "description": "Human-readable status message",
            "example": "\"Success!\""
          },
          {
            "path": "type",
            "type": "string",
            "description": "Account type identifier",
            "example": "\"twitter-sync\""
          },
          {
            "path": "params",
            "type": "object",
            "description": "Account parameters with default and user-specific settings",
            "example": "{\"default\": {}, \"user\": {}}"
          },
          {
            "path": "updated_at",
            "type": "string | null",
            "description": "Last update timestamp",
            "example": "null"
          },
          {
            "path": "account_type_hash",
            "type": "string",
            "description": "Reference to account type definition",
            "example": "\"9853173fc00a940a33d7a420c176ad3b\""
          },
          {
            "path": "squids",
            "type": "array",
            "description": "Array of squids currently using this account",
            "example": "[{\"name\": \"Twitter Scraper\", \"hash_value\": \"fcd3...\"}]"
          },
          {
            "path": "baseurl",
            "type": "string",
            "description": "Platform base URL",
            "example": "\"https://x.com\""
          },
          {
            "path": "cookies",
            "type": "array",
            "description": "Required cookie specifications",
            "example": "[{\"name\": \"auth_token\", \"required\": true}]"
          },
          {
            "path": "icon",
            "type": "string",
            "description": "Base64 encoded platform icon",
            "example": "\"<base64 image data>\""
          }
        ]
      }
    },
    "parameters": [
      {
        "name": "account_hash",
        "type": "string",
        "required": true,
        "description": "The unique identifier (hash) of the account",
        "example": "d3e97f2cd33658f301bdbe807402ab30"
      }
    ],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Check the squids array to see which squids are using this account before deleting or updating it."
      },
      {
        "type": "warning",
        "content": "Monitor the status field regularly. A status of 429 or 401 indicates cookie expiration and requires re-synchronization."
      },
      {
        "type": "note",
        "content": "The params object contains both default limits and current user-configured values, useful for understanding account usage."
      }
    ]
  },
  "seo": {
    "title": "Get Account Details - lobstr.io API Documentation",
    "description": "Learn how to retrieve detailed information about a specific platform account using the lobstr.io API."
  }
}
