{
  "slug": "get-run-tasks",
  "title": "Get Run Tasks",
  "description": "Retrieve a list of all tasks executed within a specific run",
  "category": "Run",
  "metadata": {
    "method": "GET",
    "endpoint": "/v1/runtasks",
    "requiresAuth": true
  },
  "content": {
    "introduction": "This endpoint retrieves a paginated list of all tasks executed within a specific run, including their individual status, results, and parameters.",
    "sections": {
      "queryParameters": {
        "title": "Query Parameters",
        "columns": [
          {"header": "Parameter", "key": "param"},
          {"header": "Type", "key": "type"},
          {"header": "Required", "key": "required"},
          {"header": "Description", "key": "description"}
        ],
        "rows": [
          {"param": "**run**", "type": "string", "required": "Yes", "description": "The run hash ID to get tasks for"},
          {"param": "**page**", "type": "integer", "required": "No", "description": "Page number for pagination. Default: 1"},
          {"param": "**limit**", "type": "integer", "required": "No", "description": "Results per page. Default: 50, Max: 100"}
        ]
      },
      "responseFields": {
        "title": "Response Field Explanations",
        "fields": [
          {
            "path": "total_results",
            "type": "integer",
            "description": "Total number of run tasks",
            "example": "1"
          },
          {
            "path": "data",
            "type": "array",
            "description": "Array of run task objects",
            "example": "[...]"
          },
          {
            "path": "data[].id",
            "type": "string",
            "description": "Unique run task identifier",
            "example": "\"1262f6f99dac7dffb05a513fff0ded77\""
          },
          {
            "path": "data[].object",
            "type": "string",
            "description": "Always \"runtask\"",
            "example": "\"runtask\""
          },
          {
            "path": "data[].task",
            "type": "string",
            "description": "Original task identifier",
            "example": "\"d30334cd8d21ab16048c5e2e7136a9f1\""
          },
          {
            "path": "data[].run",
            "type": "string",
            "description": "Parent run identifier",
            "example": "\"300e9c5c127d421c90f431478d9a2cfb\""
          },
          {
            "path": "data[].status",
            "type": "string",
            "description": "Task execution status (completed, aborted, error, etc.)",
            "example": "\"aborted\""
          },
          {
            "path": "data[].params",
            "type": "object",
            "description": "Task parameters",
            "example": "{\"url\": \"https://...\"}"
          },
          {
            "path": "data[].started_at",
            "type": "string",
            "description": "When task execution started",
            "example": "\"2025-02-10T14:30:58Z\""
          },
          {
            "path": "data[].ended_at",
            "type": "string",
            "description": "When task execution ended",
            "example": "\"2025-02-10T14:31:10Z\""
          },
          {
            "path": "data[].total_results",
            "type": "integer",
            "description": "Total results expected from this task",
            "example": "138"
          },
          {
            "path": "data[].last_result",
            "type": "integer",
            "description": "Number of results actually collected",
            "example": "6"
          },
          {
            "path": "data[].total_pages",
            "type": "integer",
            "description": "Total pages processed",
            "example": "1"
          },
          {
            "path": "data[].done_reason",
            "type": "string",
            "description": "Reason for task completion",
            "example": "\"run_aborted\""
          }
        ]
      }
    },
    "parameters": [],
    "headers": [
      {
        "key": "Authorization",
        "value": "Token YOUR_API_KEY",
        "required": true,
        "description": "Your API authentication token"
      }
    ],
    "proTips": [
      {
        "type": "tip",
        "content": "Use this endpoint to debug which specific tasks failed or were incomplete in a run."
      },
      {
        "type": "note",
        "content": "The done_reason field on individual tasks can differ from the overall run's done_reason."
      },
      {
        "type": "tip",
        "content": "Compare total_results vs last_result to see if a task collected all expected data."
      }
    ]
  },
  "seo": {
    "title": "Get Run Tasks - Lobstr.io API Documentation",
    "description": "Learn how to retrieve task-level details for a scraping run using the Lobstr.io API."
  }
}
