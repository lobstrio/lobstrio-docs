import requests

API_KEY = "YOUR_API_KEY"
BASE_URL = "https://api.lobstr.io/v1"
headers = {"Authorization": f"Token {API_KEY}"}

squid_id = "YOUR_SQUID_HASH"
run_id = "YOUR_RUN_HASH"

# Get message sending results
response = requests.get(f"{BASE_URL}/results",
    headers=headers,
    params={"squid": squid_id, "run": run_id}
)

data = response.json()
print(f"Total results: {data['total_results']}")

for result in data["data"]:
    print(f"\nListing: {result['annonce_id']}")
    print(f"  URL: {result['url']}")
    print(f"  Sent: {result['is_sent']}")
    if result.get('was_already_sent'):
        print("  Status: Already sent (skipped)")
    elif result.get('is_deactivated'):
        print("  Status: Listing deactivated (skipped)")
    elif result['is_sent']:
        print("  Status: Message sent successfully")
    print(f"  Message: {result['message'][:50]}...")
