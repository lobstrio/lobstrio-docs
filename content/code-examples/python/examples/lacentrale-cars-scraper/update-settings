import requests

API_KEY = "YOUR_API_KEY"
BASE_URL = "https://api.lobstr.io/v1"
headers = {"Authorization": f"Token {API_KEY}"}

squid_id = "YOUR_SQUID_HASH"

# Update squid settings
payload = {
    "name": "LaCentrale Cars Scraper (1)",
    "concurrency": 5,
    "export_unique_results": True,
    "to_complete": False,
    "no_line_breaks": True,
    "params": {
        "max_pages": 50,           # Limit pages to scrape
        "fetch_since": "7d",          # Only listings from last 24 hours
        "annonce_details": True    # Fetch detailed listing info
    }
}

response = requests.post(f"{BASE_URL}/squids/{squid_id}",
    headers=headers,
    json=payload
)

print(f"Settings updated: {response.json()['name']}")
