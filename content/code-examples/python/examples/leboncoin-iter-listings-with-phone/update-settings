import requests

API_KEY = "YOUR_API_KEY"
BASE_URL = "https://api.lobstr.io/v1"
headers = {"Authorization": f"Token {API_KEY}"}

squid_id = "YOUR_SQUID_HASH"

# Update scraper settings with phone extraction enabled
response = requests.post(f"{BASE_URL}/squids/{squid_id}",
    headers=headers,
    json={
        "name": "Leboncoin Listings & Phone Search Export (1)",
        "concurrency": 1,
        "export_unique_results": True,
        "to_complete": False,
        "no_line_breaks": True,
        "params": {
            "fetch_since": None,
            "functions": {
                "phone": True  # Enable phone number extraction
            },
            "max_pages": 99,
            "fetch_since": None,
            "max_results": None,
            "online_shop": True
        }
    }
)

print(response.json())
